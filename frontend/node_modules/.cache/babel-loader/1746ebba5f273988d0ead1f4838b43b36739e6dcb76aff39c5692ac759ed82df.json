own\">\n              <el-dropdown-item v-if=\"user?.role === 1\" @click.native=\"$router.push('/creator')\">创作者后台</el-dropdown-item>\n              <el-dropdown-item v-if=\"user?.role === 2\" @click.native=\"$router.push('/admin')\">系统后台</el-dropdown-item>\n              <el-dropdown-item divided @click.native=\"logout\">退出登录</el-dropdown-item>\n            </el-dropdown-menu>\n          </el-dropdown>\n        </div>\n      </el-header>\n      <el-main>\n        <div class=\"banner\">\n          <h1>发现优质知识专栏</h1>\n          <p>涵盖技术、设计、管理等多领域实战内容</p>\n        </div>\n        <div class=\"column-list\">\n          <el-row :gutter=\"20\">\n            <el-col :span=\"6\" v-for=\"item in columns\" :key=\"item.id\" style=\"margin-bottom: 20px;\">\n              <el-card :body-style=\"{ padding: '0px' }\" class=\"column-card\" @click.native=\"goDetail(item.id)\">\n                <img :src=\"item.cover || 'https://via.placeholder.com/300x150?text=Column+Cover'\" class=\"image\">\n                <div style=\"padding: 14px;\">\n                  <h3 class=\"title\">{{ item.title }}</h3>\n                  <p class=\"desc\">{{ item.description }}</p>\n                  <div class=\"bottom clearfix\">\n                    <span class=\"price\" v-if=\"item.price > 0\">¥ {{ item.price }}</span>\n                    <span class=\"price free\" v-else>免费</span>\n                  </div>\n                </div>\n              </el-card>\n            </el-col>\n          </el-row>\n        </div>\n      </el-main>\n    </el-container>\n  </div>\n</template>\n\n<script>\nimport { mapState, mapGetters, mapMutations } from 'vuex'\nimport request from '@/api/request'\n\nexport default {\n  name: 'HomeView',\n  data() {\n    return {\n      columns: []\n    }\n  },\n  computed: {\n    ...mapState(['user']),\n    ...mapGetters(['isLoggedIn'])\n  },\n  created() {\n    this.fetchColumns()\n  },\n  methods: {\n    ...mapMutations(['LOGOUT']),\n    logout() {\n      this.LOGOUT()\n      t