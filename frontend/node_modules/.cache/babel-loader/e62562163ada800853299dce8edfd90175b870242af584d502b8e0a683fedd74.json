icles(col) {\n      this.currentColumn = col;\n      this.activeTab = 'articles';\n      this.fetchArticles(col.id);\n    },\n    fetchArticles: function fetchArticles(columnId) {\n      var _this4 = this;\n      request.get('/article/list/' + columnId).then(function (res) {\n        _this4.currentArticles = res;\n      });\n    },\n    publishArticle: function publishArticle() {\n      var _this5 = this;\n      this.articleForm.columnId = this.currentColumn.id;\n      request.post('/article/publish', this.articleForm).then(function () {\n        _this5.$message.success('发布成功');\n        _this5.showPublishArticle = false;\n        _this5.fetchArticles(_this5.currentColumn.id);\n        // 清空表单\n        _this5.articleForm = {\n          title: '',\n          content: '',\n          isFree: 0,\n          sortOrder: 0\n        };\n      });\n    }\n  })\n};","map":{"version":3,"names":["request","mapState","mapMutations","data","activeTab","myColumns","currentColumn","currentArticles","showCreateColumn","columnForm","title","description","cover","price","showPublishArticle","articleForm","content","isFree","sortOrder","computed","_objectSpread","created","fetchColumns","methods","logout","LOGOUT","$router","push","_this","get","then","res","createColumn","_this2","post","$message","success","downColumn","id","_this3","$confirm","type","concat","manageArticles","col","fetchArticles","columnId","_this4","publishArticle","_this5"],"sources":["src/views/CreatorView.vue"],"sourcesContent":["<template>\n  <div class=\"creator-container\">\n    <el-container style=\"height: 100vh;\">\n      <el-aside width=\"220px\" style=\"background-color: #304156;\" class=\"fade-in\">\n        <div class=\"logo\">创作者中心</div>\n        <el-menu\n          default-active=\"1\"\n          class=\"el-menu-vertical\"\n          background-color=\"#304156\"\n          text-color=\"#bfcbd9\"\n          active-text-color=\"#409EFF\"\n        >\n          <el-menu-item index=\"1\" @click=\"activeTab = 'columns'\">\n            <i class=\"el-icon-menu\"></i>\n            <span slot=\"title\">我的专栏</span>\n          </el-menu-item>\n          <el-menu-item index=\"2\" @click=\"$router.push('/')\">\n            <i class=\"el-icon-back\"></i>\n            <span slot=\"title\">返回前台首页</span>\n          </el-menu-item>\n        </el-menu>\n      </el-aside>\n\n      <el-container>\n        <el-header style=\"text-align: right; font-size: 14px\" class=\"fade-in\">\n          <el-dropdown>\n            <i class=\"el-icon-setting\" style=\"margin-right: 15px\"></i>\n            <el-dropdown-menu slot=\"dropdown\">\n              <el-dropdown-item @click.native=\"logout\">退出登录</el-dropdown-item>\n            </el-dropdown-menu>\n          </el-dropdown>\n          <span>{{ user?.username || '创作者' }}</span>\n        </el-header>\n\n        <el-main class=\"fade-in\" style=\"animation-delay: 0.2s\">\n          <div v-show=\"activeTab === 'columns'\">\n            <div style=\"margin-bottom: 20px;\">\n              <el-button type=\"primary\" @click=\"showCreateColumn = true\">创建新专栏</el-button>\n            </div>\n            \n            <el-table :data=\"myColumns\" border style=\"width: 100%\">\n              <el-table-column prop=\"id\" label=\"ID\" width=\"80\"></el-table-column>\n              <el-table-column prop=\"title\" label=\"专栏标题\"></el-table-column>\n              <el-table-column prop=\"price\" label=\"价格\" width=\"100\"></el-table-column>\n              <el-table-column label=\"状态\" width=\"100\">\n                <template slot-scope=\"scope\">\n                  <el-tag :type=\"scope.row.status === 1 ? 'success' : 'info'\">{{ scope.row.status === 1 ? '已发布' : '草稿' }}</el-tag>\n                </template>\n              </el-table-column>\n              <el-table-column label=\"操作\" width=\"250\">\n                <template slot-scope=\"scope\">\n                  <el-button size=\"mini\" @click=\"manageArticles(scope.row)\">管理文章</el-button>\n                  <el-button size=\"mini\" type=\"danger\" @click=\"downColumn(scope.row.id)\" v-if=\"scope.row.status === 1\">下架</el-button>\n                </template>\n              </el-table-column>\n            </el-table>\n          </div>\n          \n          <div v-show=\"activeTab === 'articles'\">\n             <div style=\"display: flex; justify-content: space-between; margin-bottom: 20px;\">\n                <h3>《{{ currentColumn?.title }}》 - 文章管理</h3>\n                <div>\n                  <el-button type=\"success\" @click=\"showPublishArticle = true\">发布新文章</el-button>\n                  <el-button @click=\"activeTab = 'columns'\">返回专栏列表</el-button>\n                </div>\n             </div>\n             <el-table :data=\"currentArticles\" border style=\"width: 100%\">\n               <el-table-column prop=\"title\" label=\"文章标题\"></el-table-column>\n               <el-table-column prop=\"isFree\" label=\"收费类型\" width=\"120\">\n                 <template slot-scope=\"scope\">\n                   <el-tag :type=\"scope.row.isFree ? 'success' : 'warning'\">{{ scope.row.isFree ? '免费' : '付费' }}</el-tag>\n                 </template>\n               </el-table-column>\n               <el-table-column prop=\"sortOrder\" label=\"排序\" width=\"80\"></el-table-column>\n             </el-table>\n          </div>\n        </el-main>\n      </el-container>\n    </el-container>\n\n    <!-- 创建专栏 Dialog -->\n    <el-dialog title=\"新建专栏\" :visible.sync=\"showCreateColumn\" width=\"500px\">\n      <el-form :model=\"columnForm\" label-width=\"80px\">\n        <el-form-item label=\"标题\">\n          <el-input v-model=\"columnForm.title\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"描述\">\n          <el-input type=\"textarea\" v-model=\"columnForm.description\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"封面URL\">\n          <el-input v-model=\"columnForm.cover\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"价格\">\n          <el-input-number v-model=\"columnForm.price\" :min=\"0\" :precision=\"2\" :step=\"0.1\"></el-input-number>\n        </el-form-item>\n      </el-form>\n      <div slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"showCreateColumn = false\">取 消</el-button>\n        <el-button type=\"primary\" @click=\"createColumn\">确 定</el-button>\n      </div>\n    </el-dialog>\n    \n    <!-- 发布文章 Dialog -->\n    <el-dialog title=\"发布文章\" :visible.sync=\"showPublishArticle\" width=\"800px\" top=\"5vh\">\n      <el-form :model=\"articleForm\" label-width=\"80px\">\n        <el-form-item label=\"文章标题\">\n          <el-input v-model=\"articleForm.title\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"正文\">\n          <el-input type=\"textarea\" :rows=\"15\" v-model=\"articleForm.content\" placeholder=\"支持Markdown格式或者原生排版...\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"是否免费\">\n          <el-switch v-model=\"articleForm.isFree\" :active-value=\"1\" :inactive-value=\"0\"></el-switch>\n        </el-form-item>\n        <el-form-item label=\"显示排序\">\n          <el-input-number v-model=\"articleForm.sortOrder\" :min=\"0\"></el-input-number>\n        </el-form-item>\n      </el-form>\n      <div slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"showPublishArticle = false\">取 消</el-button>\n        <el-button type=\"primary\" @click=\"publishArticle\">确 定</el-button>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport request from '@/api/request'\nimport { mapState, mapMutations } from 'vuex'\n\nexport default {\n  data() {\n    return {\n      activeTab: 'columns',\n      myColumns: [],\n      currentColumn: null,\n      currentArticles: [],\n      showCreateColumn: false,\n      columnForm: {\n        title: '',\n        description: '',\n        cover: '',\n        price: 0\n      },\n      showPublishArticle: false,\n      articleForm: {\n        title: '',\n        content: '',\n        isFree: 0,\n        sortOrder: 0\n      }\n    }\n  },\n  computed: {\n    ...mapState(['user'])\n  },\n  created() {\n    this.fetchColumns()\n  },\n  methods: {\n    ...mapMutations(['LOGOUT']),\n    logout() {\n      this.LOGOUT()\n      this.$router.push('/login')\n    },\n    fetchColumns() {\n      request.get('/column/my').then(res => {\n        this.myColumns = res\n      })\n    },\n    createColumn() {\n      request.post('/column/create', this.columnForm).then(() => {\n        this.$message.success('创建成功')\n        this.showCreateColumn = false\n        this.fetchColumns()\n      })\n    },\n    downColumn(id) {\n      this.$confirm('确认下架该专栏吗？', '操作确认', { type: 'warning' }).then(() => {\n        request.post(`/admin/column/status?id=${id}&status=0`).then(() => {\n          this.$message.success('已下架该专栏')\n          this.fetchColumns()\n        }).catch(() => {})\n      }).catch(() => {})\n    },\n    manageArticles(col) {\n      this.currentColumn = col\n      this.activeTab = 'articles'\n      this.fetchArticles(col.id)\n    },\n    fetchArticles(columnId) {\n      request.get('/article/list/' + columnId).then(res => {\n        this.currentArticles = res\n      })\n    },\n    publishArticle() {\n      this.articleForm.columnId = this.currentColumn.id\n      request.post('/article/publish', this.articleForm).then(() => {\n         this.$message.success('发布成功')\n         this.showPublishArticle = false\n         this.fetchArticles(this.currentColumn.id)\n         // 清空表单\n         this.articleForm = { title: '', content: '', isFree: 0, sortOrder: 0 }\n      })\n    }\n  }\n}\n</script>\n\n<style scoped>\n.logo {\n  height: 60px;\n  line-height: 60px;\n  text-align: center;\n  color: #fff;\n  font-size: 18px;\n  font-weight: bold;\n  border-bottom: 1px solid #1f2d3d;\n}\n.el-header {\n  background-color: #fff;\n  color: #333;\n  line-height: 60px;\n  border-bottom: 1px solid #ebeef5;\n}\n</style>\n"],"mappings":";;AA+HA,OAAAA,OAAA;AA