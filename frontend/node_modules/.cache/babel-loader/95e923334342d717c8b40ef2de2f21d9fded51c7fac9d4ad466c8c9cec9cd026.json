icles(col) {\n      this.currentColumn = col;\n      this.activeTab = 'articles';\n      this.fetchArticles(col.id);\n    },\n    fetchArticles: function fetchArticles(columnId) {\n      var _this4 = this;\n      request.get('/article/list/' + columnId).then(function (res) {\n        _this4.currentArticles = res;\n      });\n    },\n    publishArticle: function publishArticle() {\n      var _this5 = this;\n      this.articleForm.columnId = this.currentColumn.id;\n      request.post('/article/publish', this.articleForm).then(function () {\n        _this5.$message.success('发布成功');\n        _this5.showPublishArticle = false;\n        _this5.fetchArticles(_this5.currentColumn.id);\n        // 清空表单\n        _this5.articleForm = {\n          title: '',\n          content: '',\n          isFree: 0,\n          sortOrder: 0\n        };\n      });\n    }\n  })\n};","map":{"version":3,"names":["request","mapState","mapMutations","data","activeTab","myColumns","currentColumn","currentArticles","showCreateColumn","columnForm","title","description","cover","price","showPublishArticle","articleForm","content","isFree","sortOrder","computed","_objectSpread","created","fetchColumns","methods","logout","LOGOUT","$router","push","_this","get","then","res","createColumn","_this2","post","$message","success","downColumn","id","_this3","$confirm","type","concat","manageArticles","col","fetchArticles","columnId","_this4","publishArticle","_this5"],"sources":["src/views/CreatorView.vue"],"sourcesContent":["<template>\n  <div class=\"creator-container\">\n    <el-container style=\"height: 100vh;\">\n      <el-aside width=\"220px\" style=\"background-color: #304156;\" class=\"fade-in\">\n        <div class=\"logo\">创作者中心</div>\n        <el-menu\n          default-active=\"1\"\n          class=\"el-menu-vertical\"\n          background-color=\"#304156\"\n          text-color=\"#bfcbd9\"\n          active-text-color=\"#409EFF\"\n        >\n          <el-menu-item index=\"1\" @click=\"activeTab = 'columns'\">\n            <i class=\"el-icon-menu\"></i>\n            <span slot=\"title\">我的专栏</span>\n          </el-menu-item>\n          <el-menu-item index=\"2\" @click=\"$router.push('/')\">\n            <i class=\"el-icon-back\"></i>\n            <span slot=\"title\">返回前台首页</span>\n          </el-menu-item>\n        </el-menu>\n      </el-aside>\n\n      <el-container>\n        <el-header style=\"text-align: right; font-size: 14px\" class=\"fade-in\">\n          <el-dropdown>\n            <i class=\"el-icon-setting\" style=\"margin-right: 15px\"></i>\n            <el-dropdown-menu slot=\"dropdown\">\n              <el-dropdown-item @click.native=\"logout\">退出登录</el-dropdown-item>\n            </el-dropdown-menu>\n          </el-dropdown>\n          <span>{{ user?.username || '创作者' }}</span>\n        </el-header>\n\n         <el-main class=\"fade-in\" style=\"animation-delay: 0.2s\">\n          <div v-show=\"activeTab === 'columns'\">\n            <div style=\"margin-bottom: 20px;\">\n              <el-button type=\"primary\" icon=\"el-icon-plus\" @click=\"showCreateColumn = true\">创建新专栏</el-button>\n            </div>\n            \n            <el-table :data=\"myColumns\" border style=\"width: 100%\" class=\"modern-table\">\n              <el-table-column prop=\"id\" label=\"ID\" width=\"80\"></el-table-column>\n              <el-table-column prop=\"title\" label=\"专栏标题\">\n                <template slot-scope=\"scope\">\n                  <span style=\"font-weight: bold; color: #409EFF\">{{ scope.row.title }}</span>\n                </template>\n              </el-table-column>\n              <el-table-column prop=\"price\" label=\"价格\" width=\"100\">\n                <template slot-scope=\"scope\">\n                  <span style=\"color: #f56c6c\">¥{{ scope.row.price }}</span>\n                </template>\n              </el-table-column>\n              <el-table-column label=\"状态\" width=\"100\">\n                <template slot-scope=\"scope\">\n                  <el-tag :type=\"scope.row.status === 1 ? 'success' : 'info'\" effect=\"dark\">{{ scope.row.status === 1 ? '已发布' : '草稿' }}</el-tag>\n                </template>\n              </el-table-column>\n              <el-table-column label=\"操作\" width=\"280\">\n                <template slot-scope=\"scope\">\n                  <el-button size=\"mini\" type=\"primary\" plain icon=\"el-icon-folder-opened\" @click=\"manageArticles(scope.row)\">管理内容</el-button>\n                  <el-button size=\"mini\" type=\"danger\" plain icon=\"el-icon-bottom\" @click=\"downColumn(scope.row.id)\" v-if=\"scope.row.status === 1\">下架</el-button>\n                </template>\n              </el-table-column>\n            </el-table>\n          </div>\n          \n          <div v-show=\"activeTab === 'articles'\">\n             <div class=\"content-header\">\n                <div class=\"header-info\">\n                  <el-page-header @back=\"activeTab = 'columns'\" :content=\"'内容管理：' + currentColumn?.title\"></el-page-header>\n                </div>\n                <div class=\"header-actions\">\n                  <el-button type=\"primary\" size=\"small\" icon=\"el-icon-folder-add\" @click=\"showCreateChapter = true\">新建章节</el-button>\n                  <el-button type=\"success\" size=\"small\" icon=\"el-icon-edit\" @click=\"openPublishModal\">发布文章</el-button>\n                </div>\n             </div>\n\n             <div class=\"chapter-content-box\">\n                <!-- 章节循环 -->\n                <div v-for=\"chapter in columnChapters\" :key=\"chapter.id\" class=\"chapter-item\">\n                   <div class=\"chapter-title-bar\">\n                      <div class=\"title-text\">\n                        <i class=\"el-icon-collection-tag\"></i> {{ chapter.title }}\n                      </div>\n                      <div class=\"title-ops\">\n                        <el-button type=\"text\" size=\"mini\" icon=\"el-icon-delete\" style=\"color: #f56c6c\" @click=\"deleteChapter(chapter.id)\">删除章节</el-button>\n                      </div>\n                   </div>\n                   <el-table :data=\"getArticlesByChapter(chapter.id)\" border size=\"small\" style=\"width: 100%\">\n                      <el-table-column prop=\"title\" label=\"文章标题\"></el-table-column>\n                      <el-table-column prop=\"isFree\" label=\"类型\" width=\"100\">\n                        <template slot-scope=\"scope\">\n                          <el-tag size=\"mini\" :type=\"scope.row.isFree ? 'success' : 'warning'\">{{ scope.row.isFree ? '免费' : '付费' }}</el-tag>\n                        </template>\n                      </el-table-column>\n                      <el-table-column prop=\"sortOrder\" label=\"排序\" width=\"80\"></el-table-column>\n                      <el-table-column label=\"操作\" width=\"120\">\n                        <template slot-scope=\"scope\">\n                          <el-button type=\"text\" size=\"mini\" @click=\"editArticle(scope.row)\">编辑</el-button>\n                          <el-button type=\"text\" size=\"mini\" style=\"color: #f56c6c\">下架</el-button>\n                        </template>\n                      </el-table-column>\n                   </el-table>\n                </div>\n\n                <!-- 未分类文章 -->\n                <div v-if=\"getArticlesByChapter(null).length > 0\" class=\"chapter-item\">\n                   <div class=\"chapter-title-bar\">\n                      <div class=\"title-text\"><i class=\"el-icon-document-remove\"></i> 未分类文章</div>\n                   </div>\n                   <el-table :data=\"getArticlesByChapter(null)\" border size=\"small\" style=\"width: 100%\">\n                      <el-table-column prop=\"title\" label=\"文章标题\"></el-table-column>\n                      <el-table-column prop=\"isFree\" label=\"类型\" width=\"100\">\n                        <template slot-scope=\"scope\">\n                          <el-tag size=\"mini\" :type=\"scope.row.isFree ? 'success' : 'warning'\">{{ scope.row.isFree ? '免费' : '付费' }}</el-tag>\n                        </template>\n                      </el-table-column>\n                      <el-table-column prop=\"sortOrder\" label=\"排序\" width=\"80\"></el-table-column>\n                      <el-table-column label=\"操作\" width=\"120\">\n                        <template slot-scope=\"scope\">\n                          <el-button type=\"text\" size=\"mini\" @click=\"editArticle(scope.row)\">编辑</el-button>\n                        </template>\n                      </el-table-column>\n                   </el-table>\n                </div>\n                \n                <el-empty v-if=\"columnChapters.length === 0 && currentArticles.length === 0\" description=\"暂无内容，请先创建章节或发布文章\"></el-empty>\n             </div>\n          </div>\n        </el-main>\n      </el-container>\n    </el-container>\n\n    <!-- 创建专栏 Dialog -->\n    <el-dialog title=\"新建专栏\" :visible.sync=\"showCreateColumn\" width=\"500px\">\n      <el-form :model=\"columnForm\" label-width=\"80px\">\n        <el-form-item label=\"标题\">\n          <el-input v-model=\"columnForm.title\" placeholder=\"请输入专栏精炼的标题\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"描述\">\n          <el-input type=\"textarea\" v-model=\"columnForm.description\" placeholder=\"简单介绍引导读者订阅...\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"封面URL\">\n          <el-input v-model=\"columnForm.cover\" placeholder=\"建议使用 16:9 的高清图\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"价格\">\n          <el-input-number v-model=\"columnForm.price\" :min=\"0\" :precision=\"2\" :step=\"1\" style=\"width: 100%\"></el-input-number>\n        </el-form-item>\n      </el-form>\n      <div slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"showCreateColumn = false\">取 消</el-button>\n        <el-button type=\"primary\" @click=\"createColumn\">立即创建</el-button>\n      </div>\n    </el-dialog>\n\n    <!-- 新建章节 Dialog -->\n    <el-dialog title=\"新建章节\" :visible.sync=\"showCreateChapter\" width=\"400px\">\n      <el-form :model=\"chapterForm\" label-width=\"80px\">\n        <el-form-item label=\"章节名称\">\n          <el-input v-model=\"chapterForm.title\" placeholder=\"如：第一章 准备工作\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"显示排序\">\n          <el-input-number v-model=\"chapterForm.sortOrder\" :min=\"0\" style=\"width: 100%\"></el-input-number>\n        </el-form-item>\n      </el-form>\n      <div slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"showCreateChapter = false\">取 消</el-button>\n        <el-button type=\"primary\" @click=\"createChapter\">确 定</el-button>\n      </div>\n    </el-dialog>\n    \n    <!-- 发布/编辑文章 Dialog (全屏模式以获得更好的 MD 编辑体验) -->\n    <el-dialog :title=\"articleForm.id ? '编辑文章' : '发布新文章'\" :visible.sync=\"showPublishArticle\" fullscreen>\n      <div class=\"article-edit-container\">\n        <el-form :model=\"articleForm\" label-position=\"top\">\n          <el-row :gutter=\"20\">\n            <el-col :span=\"12\">\n              <el-form-item label=\"文章标题\">\n                <el-input v-model=\"articleForm.title\" placeholder=\"好的标题能吸引更多读者\"></el-input>\n              </el-form-item>\n            </el-col>\n            <el-col :span=\"6\">\n              <el-form-item label=\"所属章节\">\n                <el-select v-model=\"articleForm.chapterId\" placeholder=\"请选择章节\" style=\"width: 100%\" clearable>\n                  <el-option v-for=\"c in columnChapters\" :key=\"c.id\" :label=\"c.title\" :value=\"c.id\"></el-option>\n                </el-select>\n              </el-form-item>\n            </el-col>\n            <el-col :span=\"3\">\n              <el-form-item label=\"免费试看\">\n                <el-switch v-model=\"articleForm.isFree\" :active-value=\"1\" :inactive-value=\"0\"></el-switch>\n              </el-form-item>\n            </el-col>\n            <el-col :span=\"3\">\n              <el-form-item label=\"排序权重\">\n                <el-input-number v-model=\"articleForm.sortOrder\" :min=\"0\" style=\"width: 100%\"></el-input-number>\n              </el-form-item>\n            </el-col>\n          </el-row>\n          \n          <el-form-item label=\"文章正文 (支持 Markdown)\">\n            <mavon-editor \n              v-model=\"articleForm.content\" \n              style=\"min-height: calc(100vh - 280px)\" \n              placeholder=\"开始您的创作之旅吧...\"\n              :boxShadow=\"false\"\n            />\n          </el-form-item>\n        </el-form>\n      </div>\n      <div slot=\"footer\" class=\"dialog-footer\" style=\"padding-top: 0\">\n        <el-button @click=\"showPublishArticle = false\">舍弃并返回</el-button>\n        <el-button type=\"primary\" size=\"large\" @click=\"publishArticle\" style=\"padding-left: 40px; padding-right: 40px\">\n          {{ articleForm.id ? '保存修改' : '立即发布' }}\n        </el-button>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport request from '@/api/request'\nimport { mapState, mapMutations } from 'vuex'\n\nexport default {\n  data() {\n    return {\n      activeTab: 'columns',\n      myColumns: [],\n      currentColumn: null,\n      currentArticles: [],\n      showCreateColumn: false,\n      columnForm: {\n        title: '',\n        description: '',\n        cover: '',\n        price: 0\n      },\n      showPublishArticle: false,\n      articleForm: {\n        title: '',\n        content: '',\n        isFree: 0,\n        sortOrder: 0\n      }\n    }\n  },\n  computed: {\n    ...mapState(['user'])\n  },\n  created() {\n    this.fetchColumns()\n  },\n  methods: {\n    ...mapMutations(['LOGOUT']),\n    logout() {\n      this.LOGOUT()\n      this.$router.push('/login')\n    },\n    fetchColumns() {\n      request.get('/column/my').then(res => {\n        this.myColumns = res\n      })\n    },\n    createColumn() {\n      request.post('/column/create', this.columnForm).then(() => {\n        this.$message.success('创建成功')\n        this.showCreateColumn = false\n        this.fetchColumns()\n      })\n    },\n    downColumn(id) {\n      this.$confirm('确认下架该专栏吗？', '操作确认', { type: 'warning' }).then(() => {\n        request.post(`/admin/column/status?id=${id}&status=0`).then(() => {\n          this.$message.success('已下架该专栏')\n          this.fetchColumns()\n        }).catch(() => {})\n      }).catch(() => {})\n    },\n    manageArticles(col) {\n      this.currentColumn = col\n      this.activeTab = 'articles'\n      this.fetchArticles(col.id)\n    },\n    fetchArticles(columnId) {\n      request.get('/article/list/' + columnId).then(res => {\n        this.currentArticles = res\n      })\n    },\n    publishArticle() {\n      this.articleForm.columnId = this.currentColumn.id\n      request.post('/article/publish', this.articleForm).then(() => {\n         this.$message.success('发布成功')\n         this.showPublishArticle = false\n         this.fetchArticles(this.currentColumn.id)\n         // 清空表单\n         this.articleForm = { title: '', content: '', isFree: 0, sortOrder: 0 }\n      })\n    }\n  }\n}\n</script>\n\n<style scoped>\n.logo {\n  height: 60px;\n  line-height: 60px;\n  text-align: center;\n  color: #fff;\n  font-size: 18px;\n  font-weight: bold;\n  border-bottom: 1px solid #1f2d3d;\n}\n.el-header {\n  background-color: #fff;\n  color: #333;\n  line-height: 60px;\n  border-bottom: 1px solid #ebeef5;\n}\n</style>\n"],"mappings":";;AA6NA,OAAAA,OAAA;AACA,SAAAC,QAAA,EAAAC,YAAA;AAEA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,SAAA;MACAC,SAAA;MACAC,aAAA;MACAC,eAAA;MACAC,gBAAA;MACAC,UAAA;QACAC,KAAA;QACAC,WAAA;QACAC,KAAA;QACAC,KAAA;MACA;MACAC,kBAAA;MACAC,WAAA;QACAL,KAAA;QACAM,OAAA;QACAC,MAAA;QACAC,SAAA;MACA;IACA;EACA;EACAC,QAAA,EAAAC,aAAA,KACAnB,QAAA,WACA;EACAoB,OAAA,WAAAA,QAAA;IACA,KAAAC,YAAA;EACA;EACAC,OAAA,EAAAH,aAAA,CAAAA,aAAA,KACAlB,YAAA;IACAsB,MAAA,WAAAA,OAAA;MACA,KAAAC,MAAA;MACA,KAAAC,OAAA,CAAAC,IAAA;IACA;IACAL,YAAA,WAAAA,aAAA;MAAA,IAAAM,KAAA;MACA5B,OAAA,CAAA6B,GAAA,eAAAC,IAAA,WAAAC,GAAA;QAC