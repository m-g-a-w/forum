{"ast":null,"code":"import _objectSpread from \"/Users/Zhuanz1/Desktop/\\u6BD5\\u4E1A\\u8BBE\\u8BA1/code/frontend/node_modules/@babel/runtime/helpers/esm/objectSpread2.js\";\nimport \"core-js/modules/es.array.concat.js\";\nimport \"core-js/modules/es.array.push.js\";\nimport request from '@/api/request';\nimport { mapState, mapMutations } from 'vuex';\nexport default {\n  data: function data() {\n    return {\n      activeTab: 'dashboard',\n      stat: {\n        userCount: 0,\n        columnCount: 0,\n        orderCount: 0,\n        subscriptionCount: 0,\n        activeUserCount: 0,\n        todayRegister: 0,\n        todayOrder: 0,\n        totalRevenue: 0\n      },\n      users: [],\n      columns: [],\n      recentUsers: [],\n      recentOrders: []\n    };\n  },\n  computed: _objectSpread({}, mapState(['user'])),\n  created: function created() {\n    this.fetchDashboard();\n  },\n  methods: _objectSpread(_objectSpread({}, mapMutations(['LOGOUT'])), {}, {\n    handleCommand: function handleCommand(cmd) {\n      if (cmd === 'logout') {\n        this.LOGOUT();\n        this.$message.success('已安全退出');\n        this.$router.push('/login');\n      } else if (cmd === 'home') {\n        this.$router.push('/');\n      }\n    },\n    handleSelect: function handleSelect(index) {\n      if (index === 'back') {\n        this.$router.push('/');\n        return;\n      }\n      this.activeTab = index;\n      if (index === 'dashboard') this.fetchDashboard();\n      if (index === 'users') this.fetchUsers();\n      if (index === 'columns') this.fetchColumns();\n    },\n    fetchDashboard: function fetchDashboard() {\n      var _this = this;\n      request.get('/admin/dashboard').then(function (res) {\n        _this.stat = _objectSpread(_objectSpread({}, _this.stat), res);\n      })[\"catch\"](function () {});\n    },\n    fetchUsers: function fetchUsers() {\n      var _this2 = this;\n      request.get('/admin/users').then(function (res) {\n        _this2.users = res;\n      });\n    },\n    fetchColumns: function fetchColumns() {\n      var _this3 = this;\n      request.get('/admin/columns').then(function (res) {\n        _this3.columns = res;\n      });\n    },\n    changeUserStatus: function changeUserStatus(row) {\n      var _this4 = this;\n      var newStatus = row.status === 1 ? 0 : 1;\n      request.post(\"/admin/user/status?id=\".concat(row.id, \"&status=\").concat(newStatus)).then(function () {\n        _this4.$message.success('更新状态成功');\n        row.status = newStatus;\n      });\n    },\n    changeColumnStatus: function changeColumnStatus(row) {\n      var _this5 = this;\n      var newStatus = row.status === 1 ? 0 : 1;\n      request.post(\"/admin/column/status?id=\".concat(row.id, \"&status=\").concat(newStatus)).then(function () {\n        _this5.$message.success('更新状态成功');\n        row.status = newStatus;\n      });\n    }\n  })\n};","map":{"version":3,"names":["request","mapState","mapMutations","data","activeTab","stat","userCount","columnCount","orderCount","subscriptionCount","activeUserCount","todayRegister","todayOrder","totalRevenue","users","columns","recentUsers","recentOrders","computed","_objectSpread","created","fetchDashboard","methods","handleCommand","cmd","LOGOUT","$message","success","$router","push","handleSelect","index","fetchUsers","fetchColumns","_this","get","then","res","_this2","_this3","changeUserStatus","row","_this4","newStatus","status","post","concat","id","changeColumnStatus","_this5"],"sources":["src/views/AdminView.vue"],"sourcesContent":["<template>\n  <div class=\"admin-container\">\n    <el-container style=\"height: 100vh;\">\n      <el-aside width=\"220px\" class=\"fade-in\">\n        <div class=\"logo\" @click=\"$router.push('/')\">\n          <i class=\"el-icon-back\"></i> 返回首页\n        </div>\n        <el-menu\n          default-active=\"dashboard\"\n          class=\"el-menu-vertical\"\n          @select=\"handleSelect\"\n        >\n          <el-menu-item index=\"dashboard\">\n            <i class=\"el-icon-data-line\"></i>\n            <span slot=\"title\">数据看板</span>\n          </el-menu-item>\n          <el-menu-item index=\"users\">\n            <i class=\"el-icon-user\"></i>\n            <span slot=\"title\">用户管理</span>\n          </el-menu-item>\n          <el-menu-item index=\"columns\">\n            <i class=\"el-icon-document\"></i>\n            <span slot=\"title\">专栏审核</span>\n          </el-menu-item>\n        </el-menu>\n      </el-aside>\n\n      <el-container>\n        <el-header height=\"60px\" class=\"admin-header fade-in\">\n          <div class=\"header-right\">\n            <el-dropdown v-if=\"user\" @command=\"handleCommand\">\n              <span class=\"user-dropdown\">\n                <el-avatar size=\"small\" :src=\"user?.avatar || (user ? 'https://api.dicebear.com/7.x/avataaars/png?seed=' + user.username : 'https://api.dicebear.com/7.x/avataaars/png?seed=default')\"></el-avatar>\n                <span class=\"username\">{{ user?.username }}</span>\n                <i class=\"el-icon-arrow-down el-icon--right\"></i>\n              </span>\n              <el-dropdown-menu slot=\"dropdown\">\n                <el-dropdown-item command=\"home\"><i class=\"el-icon-s-home\"></i> 返回前台</el-dropdown-item>\n                <el-dropdown-item command=\"logout\" divided><i class=\"el-icon-switch-button\"></i> 退出登录</el-dropdown-item>\n              </el-dropdown-menu>\n            </el-dropdown>\n          </div>\n        </el-header>\n\n        <el-main class=\"fade-in\" style=\"animation-delay: 0.2s\">\n          <!-- 数据看板 -->\n          <div v-show=\"activeTab === 'dashboard'\">\n             <h2 class=\"section-title\">全局数据看板</h2>\n             \n             <!-- 核心指标卡片 -->\n             <el-row :gutter=\"20\" style=\"margin-top: 20px;\">\n               <el-col :span=\"6\">\n                 <el-card shadow=\"hover\" class=\"stat-card\">\n                    <div class=\"stat-icon users-icon\"><i class=\"el-icon-user\"></i></div>\n                    <div class=\"stat-info\">\n                      <div class=\"stat-value\">{{ stat.userCount }}</div>\n                      <div class=\"stat-label\">总注册用户</div>\n                    </div>\n                 </el-card>\n               </el-col>\n               <el-col :span=\"6\">\n                 <el-card shadow=\"hover\" class=\"stat-card\">\n                    <div class=\"stat-icon columns-icon\"><i class=\"el-icon-document\"></i></div>\n                    <div class=\"stat-info\">\n                      <div class=\"stat-value\">{{ stat.columnCount }}</div>\n                      <div class=\"stat-label\">专栏总数</div>\n                    </div>\n                 </el-card>\n               </el-col>\n               <el-col :span=\"6\">\n                 <el-card shadow=\"hover\" class=\"stat-card\">\n                    <div class=\"stat-icon orders-icon\"><i class=\"el-icon-shopping-cart-2\"></i></div>\n                    <div class=\"stat-info\">\n                      <div class=\"stat-value\">{{ stat.orderCount }}</div>\n                      <div class=\"stat-label\">支付订单</div>\n                    </div>\n                 </el-card>\n               </el-col>\n               <el-col :span=\"6\">\n                 <el-card shadow=\"hover\" class=\"stat-card\">\n                    <div class=\"stat-icon subs-icon\"><i class=\"el-icon-s-grid\"></i></div>\n                    <div class=\"stat-info\">\n                      <div class=\"stat-value\">{{ stat.subscriptionCount || 0 }}</div>\n                      <div class=\"stat-label\">订阅总数</div>\n                    </div>\n                 </el-card>\n               </el-col>\n             </el-row>\n\n             <!-- 近期动态 -->\n             <el-row :gutter=\"20\" style=\"margin-top: 30px;\">\n               <el-col :span=\"16\">\n                 <el-card shadow=\"hover\">\n                   <div slot=\"header\" class=\"card-header\">\n                     <span><i class=\"el-icon-time\"></i> 近期活跃用户</span>\n                   </div>\n                   <el-table :data=\"recentUsers\" style=\"width: 100%\" size=\"small\">\n                     <el-table-column prop=\"username\" label=\"用户名\"></el-table-column>\n                     <el-table-column prop=\"email\" label=\"邮箱\" width=\"180\"></el-table-column>\n                     <el-table-column prop=\"createTime\" label=\"注册时间\" width=\"160\"></el-table-column>\n                   </el-table>\n                 </el-card>\n               </el-col>\n               <el-col :span=\"8\">\n                 <el-card shadow=\"hover\">\n                   <div slot=\"header\" class=\"card-header\">\n                     <span><i class=\"el-icon-pie-chart\"></i> 数据概览</span>\n                   </div>\n                   <div class=\"quick-stats\">\n                     <div class=\"quick-item\">\n                       <span class=\"quick-label\">活跃用户</span>\n                       <span class=\"quick-value\">{{ stat.activeUserCount || 0 }}</span>\n                     </div>\n                     <el-divider></el-divider>\n                     <div class=\"quick-item\">\n                       <span class=\"quick-label\">今日新注册</span>\n                       <span class=\"quick-value\">{{ stat.todayRegister || 0 }}</span>\n                     </div>\n                     <el-divider></el-divider>\n                     <div class=\"quick-item\">\n                       <span class=\"quick-label\">今日订单</span>\n                       <span class=\"quick-value\">{{ stat.todayOrder || 0 }}</span>\n                     </div>\n                     <el-divider></el-divider>\n                     <div class=\"quick-item\">\n                       <span class=\"quick-label\">总收入</span>\n                       <span class=\"quick-value highlight\">¥ {{ stat.totalRevenue || 0 }}</span>\n                     </div>\n                   </div>\n                 </el-card>\n               </el-col>\n             </el-row>\n\n             <!-- 最新订单 -->\n             <el-row style=\"margin-top: 30px;\">\n               <el-col :span=\"24\">\n                 <el-card shadow=\"hover\">\n                   <div slot=\"header\" class=\"card-header\">\n                     <span><i class=\"el-icon-document\"></i> 最新订单记录</span>\n                   </div>\n                   <el-table :data=\"recentOrders\" style=\"width: 100%\" size=\"small\">\n                     <el-table-column prop=\"id\" label=\"订单ID\" width=\"100\"></el-table-column>\n                     <el-table-column prop=\"userId\" label=\"用户ID\" width=\"100\"></el-table-column>\n                     <el-table-column prop=\"columnId\" label=\"专栏ID\" width=\"100\"></el-table-column>\n                     <el-table-column label=\"金额\" width=\"100\">\n                       <template slot-scope=\"scope\">\n                         <span class=\"price-text\">¥ {{ scope.row.amount || 0 }}</span>\n                       </template>\n                     </el-table-column>\n                     <el-table-column label=\"状态\" width=\"100\">\n                       <template slot-scope=\"scope\">\n                         <el-tag :type=\"scope.row.status === 1 ? 'success' : 'info'\" size=\"small\">\n                           {{ scope.row.status === 1 ? '已完成' : '待处理' }}\n                         </el-tag>\n                       </template>\n                     </el-table-column>\n                     <el-table-column prop=\"createTime\" label=\"下单时间\"></el-table-column>\n                   </el-table>\n                 </el-card>\n               </el-col>\n             </el-row>\n          </div>\n\n          <!-- 用户管理 -->\n          <div v-show=\"activeTab === 'users'\">\n             <h2>用户管理</h2>\n             <el-table :data=\"users\" border style=\"width: 100%\">\n               <el-table-column prop=\"id\" label=\"ID\" width=\"80\"></el-table-column>\n               <el-table-column prop=\"username\" label=\"用户名\"></el-table-column>\n               <el-table-column prop=\"email\" label=\"邮箱\"></el-table-column>\n              <el-table-column label=\"角色\">\n                <template slot-scope=\"scope\">\n                  <el-tag v-if=\"scope.row.role === 2\" type=\"danger\">管理员</el-tag>\n                  <el-tag v-else-if=\"scope.row.columnCount > 0\" type=\"success\">创作者</el-tag>\n                  <el-tag v-else type=\"info\">普通用户</el-tag>\n                </template>\n              </el-table-column>\n               <el-table-column label=\"状态\" width=\"100\">\n                 <template slot-scope=\"scope\">\n                   <el-tag :type=\"scope.row.status === 1 ? 'success' : 'danger'\">\n                     {{ scope.row.status === 1 ? '正常' : '封禁' }}\n                   </el-tag>\n                 </template>\n               </el-table-column>\n               <el-table-column label=\"操作\" width=\"150\" v-if=\"user?.role === 2\">\n                 <template slot-scope=\"scope\">\n                   <el-button \n                     size=\"mini\" \n                     :type=\"scope.row.status === 1 ? 'danger' : 'success'\"\n                     @click=\"changeUserStatus(scope.row)\"\n                     v-if=\"scope.row.role !== 2\"\n                   >\n                     {{ scope.row.status === 1 ? '封禁' : '解封' }}\n                   </el-button>\n                 </template>\n               </el-table-column>\n             </el-table>\n          </div>\n\n          <!-- 专栏审核 -->\n          <div v-show=\"activeTab === 'columns'\">\n             <h2>专栏内容管理</h2>\n             <el-table :data=\"columns\" border style=\"width: 100%\">\n               <el-table-column prop=\"id\" label=\"ID\" width=\"80\"></el-table-column>\n               <el-table-column prop=\"title\" label=\"专栏标题\"></el-table-column>\n               <el-table-column prop=\"creatorId\" label=\"创作者ID\" width=\"100\"></el-table-column>\n               <el-table-column label=\"状态\" width=\"100\">\n                 <template slot-scope=\"scope\">\n                   <el-tag :type=\"scope.row.status === 1 ? 'success' : 'danger'\">\n                     {{ scope.row.status === 1 ? '上架中' : '已下架' }}\n                   </el-tag>\n                 </template>\n               </el-table-column>\n               <el-table-column label=\"操作\" width=\"150\">\n                 <template slot-scope=\"scope\">\n                   <el-button \n                     size=\"mini\" \n                     :type=\"scope.row.status === 1 ? 'danger' : 'success'\"\n                     @click=\"changeColumnStatus(scope.row)\"\n                   >\n                     {{ scope.row.status === 1 ? '强制下架' : '恢复上架' }}\n                   </el-button>\n                 </template>\n               </el-table-column>\n             </el-table>\n          </div>\n        </el-main>\n      </el-container>\n    </el-container>\n  </div>\n</template>\n\n<script>\nimport request from '@/api/request'\nimport { mapState, mapMutations } from 'vuex'\n\nexport default {\n  data() {\n    return {\n      activeTab: 'dashboard',\n      stat: {\n        userCount: 0,\n        columnCount: 0,\n        orderCount: 0,\n        subscriptionCount: 0,\n        activeUserCount: 0,\n        todayRegister: 0,\n        todayOrder: 0,\n        totalRevenue: 0\n      },\n      users: [],\n      columns: [],\n      recentUsers: [],\n      recentOrders: []\n    }\n  },\n  computed: {\n    ...mapState(['user'])\n  },\n  created() {\n    this.fetchDashboard()\n  },\n  methods: {\n    ...mapMutations(['LOGOUT']),\n    handleCommand(cmd) {\n      if (cmd === 'logout') {\n        this.LOGOUT()\n        this.$message.success('已安全退出')\n        this.$router.push('/login')\n      } else if (cmd === 'home') {\n        this.$router.push('/')\n      }\n    },\n    handleSelect(index) {\n      if (index === 'back') {\n        this.$router.push('/')\n        return\n      }\n      this.activeTab = index\n      if (index === 'dashboard') this.fetchDashboard()\n      if (index === 'users') this.fetchUsers()\n      if (index === 'columns') this.fetchColumns()\n    },\n    fetchDashboard() {\n      request.get('/admin/dashboard').then(res => {\n        this.stat = { ...this.stat, ...res }\n      }).catch(() => {})\n    },\n    fetchUsers() {\n      request.get('/admin/users').then(res => {\n        this.users = res\n      })\n    },\n    fetchColumns() {\n      request.get('/admin/columns').then(res => {\n        this.columns = res\n      })\n    },\n    changeUserStatus(row) {\n      const newStatus = row.status === 1 ? 0 : 1\n      request.post(`/admin/user/status?id=${row.id}&status=${newStatus}`).then(() => {\n        this.$message.success('更新状态成功')\n        row.status = newStatus\n      })\n    },\n    changeColumnStatus(row) {\n      const newStatus = row.status === 1 ? 0 : 1\n      request.post(`/admin/column/status?id=${row.id}&status=${newStatus}`).then(() => {\n        this.$message.success('更新状态成功')\n        row.status = newStatus\n      })\n    }\n  }\n}\n</script>\n\n<style scoped>\n.admin-container {\n  --theme-color: #1a365d;\n  --theme-light: #4299e1;\n  --theme-bg: #f7fafc;\n}\n.admin-header {\n  background-color: #fff;\n  color: #333;\n  line-height: 60px;\n  border-bottom: 1px solid #e2e8f0;\n  display: flex;\n  align-items: center;\n  justify-content: flex-end;\n  padding: 0 20px;\n}\n.header-right {\n  display: flex;\n  align-items: center;\n}\n.user-dropdown {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  color: #333;\n  cursor: pointer;\n  font-weight: 500;\n  padding: 6px 12px;\n  border-radius: 20px;\n  transition: background-color 0.3s;\n}\n.user-dropdown:hover {\n  background-color: #f5f7fa;\n}\n.username {\n  font-size: 14px;\n}\n::v-deep .el-avatar > img {\n  object-fit: cover !important;\n  width: 100%;\n  height: 100%;\n}\n.logo {\n  height: 60px;\n  line-height: 60px;\n  text-align: center;\n  color: #fff;\n  font-size: 18px;\n  font-weight: bold;\n  background: linear-gradient(135deg, #2c5282 0%, #4299e1 100%);\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 5px;\n  transition: all 0.3s;\n}\n.logo:hover {\n  background: linear-gradient(135deg, #2c5282 0%, #63b3ed 100%);\n}\n.logo i {\n  font-weight: normal;\n}\n\n/* 数据看板样式 */\n.section-title {\n  font-size: 20px;\n  color: #2c5282;\n  font-weight: 600;\n  margin-bottom: 10px;\n}\n.stat-card {\n  display: flex;\n  align-items: center;\n  padding: 5px 0;\n  border-radius: 12px;\n  transition: transform 0.3s, box-shadow 0.3s;\n}\n.stat-card:hover {\n  transform: translateY(-5px);\n  box-shadow: 0 8px 25px rgba(0,0,0,0.1) !important;\n}\n.stat-icon {\n  width: 60px;\n  height: 60px;\n  border-radius: 12px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 28px;\n  margin-right: 15px;\n}\n.stat-icon i {\n  color: #fff;\n}\n.users-icon { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }\n.columns-icon { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }\n.orders-icon { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }\n.subs-icon { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }\n.stat-info {\n  flex: 1;\n}\n.stat-value {\n  font-size: 28px;\n  font-weight: bold;\n  color: #2c5282;\n}\n.stat-label {\n  font-size: 13px;\n  color: #909399;\n  margin-top: 5px;\n}\n.card-header {\n  font-size: 16px;\n  color: #2c5282;\n  font-weight: 600;\n}\n.card-header i {\n  margin-right: 8px;\n}\n.quick-stats {\n  padding: 10px 0;\n}\n.quick-item {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 8px 0;\n}\n.quick-label {\n  color: #606266;\n  font-size: 14px;\n}\n.quick-value {\n  color: #2c5282;\n  font-weight: 600;\n  font-size: 16px;\n}\n.quick-value.highlight {\n  color: #f56c6c;\n  font-size: 18px;\n}\n.price-text {\n  color: #f56c6c;\n  font-weight: 600;\n}\n  color: #4299e1;\n  font-size: 14px;\n}\n.card-num {\n  font-size: 32px;\n  color: #2c5282;\n  margin-top: 10px;\n  font-weight: bold;\n}\n\n/* 科技蓝侧边栏 */\n.el-aside {\n  background: linear-gradient(180deg, #2c5282 0%, #4299e1 50%, #2c5282 100%) !important;\n}\n.el-menu {\n  border-right: none !important;\n  background: transparent !important;\n}\n.el-menu-item {\n  margin: 4px 8px;\n  border-radius: 8px;\n  color: #e2e8f0 !important;\n}\n.el-menu-item i {\n  color: #e2e8f0 !important;\n}\n.el-menu-item:hover {\n  background-color: rgba(66, 153, 225, 0.3) !important;\n}\n.el-menu-item.is-active {\n  background-color: #4299e1 !important;\n  color: #fff !important;\n}\n.el-menu-item.is-active i {\n  color: #fff !important;\n}\n</style>\n"],"mappings":";;;AAyOA,OAAAA,OAAA;AACA,SAAAC,QAAA,EAAAC,YAAA;AAEA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,SAAA;MACAC,IAAA;QACAC,SAAA;QACAC,WAAA;QACAC,UAAA;QACAC,iBAAA;QACAC,eAAA;QACAC,aAAA;QACAC,UAAA;QACAC,YAAA;MACA;MACAC,KAAA;MACAC,OAAA;MACAC,WAAA;MACAC,YAAA;IACA;EACA;EACAC,QAAA,EAAAC,aAAA,KACAlB,QAAA,WACA;EACAmB,OAAA,WAAAA,QAAA;IACA,KAAAC,cAAA;EACA;EACAC,OAAA,EAAAH,aAAA,CAAAA,aAAA,KACAjB,YAAA;IACAqB,aAAA,WAAAA,cAAAC,GAAA;MACA,IAAAA,GAAA;QACA,KAAAC,MAAA;QACA,KAAAC,QAAA,CAAAC,OAAA;QACA,KAAAC,OAAA,CAAAC,IAAA;MACA,WAAAL,GAAA;QACA,KAAAI,OAAA,CAAAC,IAAA;MACA;IACA;IACAC,YAAA,WAAAA,aAAAC,KAAA;MACA,IAAAA,KAAA;QACA,KAAAH,OAAA,CAAAC,IAAA;QACA;MACA;MACA,KAAAzB,SAAA,GAAA2B,KAAA;MACA,IAAAA,KAAA,uBAAAV,cAAA;MACA,IAAAU,KAAA,mBAAAC,UAAA;MACA,IAAAD,KAAA,qBAAAE,YAAA;IACA;IACAZ,cAAA,WAAAA,eAAA;MAAA,IAAAa,KAAA;MACAlC,OAAA,CAAAmC,GAAA,qBAAAC,IAAA,WAAAC,GAAA;QACAH,KAAA,CAAA7B,IAAA,GAAAc,aAAA,CAAAA,aAAA,KAAAe,KAAA,CAAA7B,IAAA,GAAAgC,GAAA;MACA;IACA;IACAL,UAAA,WAAAA,WAAA;MAAA,IAAAM,MAAA;MACAtC,OAAA,CAAAmC,GAAA,iBAAAC,IAAA,WAAAC,GAAA;QACAC,MAAA,CAAAxB,KAAA,GAAAuB,GAAA;MACA;IACA;IACAJ,YAAA,WAAAA,aAAA;MAAA,IAAAM,MAAA;MACAvC,OAAA,CAAAmC,GAAA,mBAAAC,IAAA,WAAAC,GAAA;QACAE,MAAA,CAAAxB,OAAA,GAAAsB,GAAA;MACA;IACA;IACAG,gBAAA,WAAAA,iBAAAC,GAAA;MAAA,IAAAC,MAAA;MACA,IAAAC,SAAA,GAAAF,GAAA,CAAAG,MAAA;MACA5C,OAAA,CAAA6C,IAAA,0BAAAC,MAAA,CAAAL,GAAA,CAAAM,EAAA,cAAAD,MAAA,CAAAH,SAAA,GAAAP,IAAA;QACAM,MAAA,CAAAhB,QAAA,CAAAC,OAAA;QACAc,GAAA,CAAAG,MAAA,GAAAD,SAAA;MACA;IACA;IACAK,kBAAA,WAAAA,mBAAAP,GAAA;MAAA,IAAAQ,MAAA;MACA,IAAAN,SAAA,GAAAF,GAAA,CAAAG,MAAA;MACA5C,OAAA,CAAA6C,IAAA,4BAAAC,MAAA,CAAAL,GAAA,CAAAM,EAAA,cAAAD,MAAA,CAAAH,SAAA,GAAAP,IAAA;QACAa,MAAA,CAAAvB,QAAA,CAAAC,OAAA;QACAc,GAAA,CAAAG,MAAA,GAAAD,SAAA;MACA;IACA;EAAA;AAEA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}