  this.$router.push('/');\n        return;\n      }\n      this.activeTab = index;\n      if (index === 'dashboard') this.fetchDashboard();\n      if (index === 'users') this.fetchUsers();\n      if (index === 'columns') this.fetchColumns();\n      if (index === 'comments') this.fetchComments();\n    },\n    fetchDashboard: function fetchDashboard() {\n      var _this = this;\n      request.get('/admin/dashboard').then(function (res) {\n        // 提取统计数据\n        var recentUsers = res.recentUsers,\n          recentOrders = res.recentOrders,\n          statData = _objectWithoutProperties(res, _excluded);\n        _this.stat = _objectSpread(_objectSpread({}, _this.stat), statData);\n        _this.recentUsers = recentUsers || [];\n        _this.recentOrders = recentOrders || [];\n      })[\"catch\"](function () {});\n    },\n    fetchUsers: function fetchUsers() {\n      var _this2 = this;\n      request.get('/admin/users').then(function (res) {\n        _this2.users = res;\n      });\n    },\n    fetchColumns: function fetchColumns() {\n      var _this3 = this;\n      request.get('/admin/columns').then(function (res) {\n        _this3.columns = res;\n      });\n    },\n    changeUserStatus: function changeUserStatus(row) {\n      var _this4 = this;\n      var newStatus = row.status === 1 ? 0 : 1;\n      request.post(\"/admin/user/status?id=\".concat(row.id, \"&status=\").concat(newStatus)).then(function () {\n        _this4.$message.success('更新状态成功');\n        row.status = newStatus;\n      });\n    },\n    changeColumnStatus: function changeColumnStatus(row) {\n      var _this5 = this;\n      var newStatus = row.status === 1 ? 0 : 1;\n      request.post(\"/admin/column/status?id=\".concat(row.id, \"&status=\").concat(newStatus)).then(function () {\n        _this5.$message.success('更新状态成功');\n        row.status = newStatus;\n      });\n    },\n    // 评论管理相关方法\n    fetchComments: function fetchComments() {\n      var _this6 = this;\n      request.get('/comment/admin/list', {\n        params: {\n          keyword: this.commentSearch || null,\n          page: this.commentPage,\n          pageSize: this.commentPageSize\n        }\n      }).then(function (res) {\n        if (res && res[0]) {\n          _this6.comments = res[0].list || [];\n          _this6.commentTotal = res[0].total || 0;\n        }\n      })[\"catch\"](function () {\n        _this6.comments = [];\n        _this6.commentTotal = 0;\n      });\n      // 获取统计数据\n      request.get('/comment/admin/stats').then(function (stats) {\n        _this6.commentStats = stats || {\n          total: 0,\n          today: 0\n        };\n      })[\"catch\"](function () {});\n    },\n    handleDeleteComment: function handleDeleteComment(row) {\n      var _this7 = this;\n      this.$confirm('确定要删除这条评论吗？', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(function () {\n        request[\"delete\"](\"/comment/admin/\".concat(row.id)).then(function () {\n          _this7.$message.success('删除成功');\n          _this7.fetchComments();\n        })[\"catch\"](function () {});\n      })[\"catch\"](function () {});\n    },\n    handleSelectionChange: function handleSelectionChange(val) {\n      this.selectedComments = val;\n    },\n    handleBatchDelete: function handleBatchDelete() {\n      var _this8 = this;\n      if (this.selectedComments.length === 0) {\n        this.$message.warning('请先选择要删除的评论');\n        return;\n      }\n      this.$confirm(\"\\u786E\\u5B9A\\u8981\\u5220\\u9664\\u9009\\u4E2D\\u7684 \".concat(this.selectedComments.length, \" \\u6761\\u8BC4\\u8BBA\\u5417\\uFF1F\"), '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(function () {\n        var ids = _this8.selectedComments.map(function (c) {\n          return c.id;\n        });\n        request[\"delete\"]('/comment/admin/batch', {\n          data: ids\n        }).then(function () {\n          _this8