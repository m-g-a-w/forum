{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport request from '@/api/request';\nexport default {\n  data: function data() {\n    return {\n      column: null,\n      articles: []\n    };\n  },\n  created: function created() {\n    this.fetchData();\n  },\n  methods: {\n    fetchData: function fetchData() {\n      var _this = this;\n      var id = this.$route.params.id;\n      request.get('/column/' + id).then(function (res) {\n        _this.column = res;\n      });\n      request.get('/article/list/' + id).then(function (res) {\n        _this.articles = res;\n      });\n    },\n    subscribe: function subscribe() {\n      var _this2 = this;\n      if (!this.$store.getters.isLoggedIn) {\n        this.$message.warning('请先登录系统');\n        return this.$router.push('/login');\n      }\n      this.$confirm(\"\\u786E\\u8BA4\\u8981\\u8BA2\\u9605\\u5E76\\u652F\\u4ED8 \\xA5\".concat(this.column.price, \" \\u5417?\"), '提示', {\n        type: 'warning'\n      }).then(function () {\n        // 创建订单\n        request.post('/order/create?columnId=' + _this2.column.id).then(function (order) {\n          if (!order) {\n            _this2.$message.success('免费专栏订阅成功');\n          } else {\n            // 立即支付\n            request.post('/order/pay?orderNo=' + order.orderNo).then(function () {\n              _this2.$message.success('支付成功，已解锁该专栏');\n              // 重新加载数据或者改变按钮状态\n            })[\"catch\"](function (e) {\n              _this2.$message.error('支付失败：' + (e.message || '余额不足'));\n            });\n          }\n        });\n      })[\"catch\"](function () {});\n    },\n    readArticle: function readArticle(row) {\n      if (!this.$store.getters.isLoggedIn) {\n        this.$message.warning('请登录后阅读文章');\n        return this.$router.push('/login');\n      }\n      this.$router.push('/article/' + row.id);\n    }\n  }\n};","map":{"version":3,"names":["request","data","column","articles","created","fetchData","methods","_this","id","$route","params","get","then","res","subscribe","_this2","$store","getters","isLoggedIn","$message","warning","$router","push","$confirm","concat","price","type","post","order","success","orderNo","e","error","message","readArticle","row"],"sources":["src/views/ColumnDetailView.vue"],"sourcesContent":["<template>\n  <div class=\"column-detail\">\n    <el-container v-if=\"column\">\n      <el-header height=\"60px\">\n        <div class=\"logo\" @click=\"$router.push('/')\" style=\"cursor: pointer;\">< 返回首页</div>\n      </el-header>\n      <el-main>\n        <el-card class=\"top-card\">\n          <div class=\"info-layout\">\n            <img :src=\"column.cover || 'https://via.placeholder.com/300x150?text=Column'\" class=\"cover\" />\n            <div class=\"meta\">\n              <h2>{{ column.title }}</h2>\n              <p class=\"desc\">{{ column.description }}</p>\n              <div class=\"actions\">\n                <span class=\"price\" v-if=\"column.price > 0\">¥ {{ column.price }}</span>\n                <span class=\"price free\" v-else>免费</span>\n                <el-button v-if=\"!isSubscribed\" type=\"success\" @click=\"subscribe\" style=\"margin-left: 20px;\">\n                  {{ column.price > 0 ? '订阅专栏' : '免费加入' }}\n                </el-button>\n                <el-tag v-else type=\"success\" style=\"margin-left: 20px;\">✓ 已订阅</el-tag>\n              </div>\n            </div>\n          </div>\n        </el-card>\n\n        <!-- 文章列表 -->\n        <el-card class=\"article-card\" style=\"margin-top: 20px;\">\n          <div slot=\"header\" class=\"clearfix\">\n            <span>专栏目录</span>\n          </div>\n          <el-table :data=\"articles\" style=\"width: 100%\" @row-click=\"readArticle\" row-class-name=\"pointer-row\">\n            <el-table-column prop=\"title\" label=\"文章标题\"></el-table-column>\n            <el-table-column label=\"阅读权限\" width=\"120\">\n              <template slot-scope=\"scope\">\n                <el-tag :type=\"scope.row.isFree ? 'success' : 'warning'\" size=\"small\">\n                  {{ scope.row.isFree ? '免费试读' : '付费内容' }}\n                </el-tag>\n              </template>\n            </el-table-column>\n            <el-table-column prop=\"createTime\" label=\"发布时间\" width=\"200\"></el-table-column>\n          </el-table>\n        </el-card>\n      </el-main>\n    </el-container>\n  </div>\n</template>\n\n<script>\nimport request from '@/api/request'\n\nexport default {\n  data() {\n    return {\n      column: null,\n      articles: []\n    }\n  },\n  created() {\n    this.fetchData()\n  },\n  methods: {\n    fetchData() {\n      const id = this.$route.params.id\n      request.get('/column/' + id).then(res => {\n        this.column = res\n      })\n      request.get('/article/list/' + id).then(res => {\n        this.articles = res\n      })\n    },\n    subscribe() {\n      if (!this.$store.getters.isLoggedIn) {\n        this.$message.warning('请先登录系统')\n        return this.$router.push('/login')\n      }\n      this.$confirm(`确认要订阅并支付 ¥${this.column.price} 吗?`, '提示', {\n        type: 'warning'\n      }).then(() => {\n        // 创建订单\n        request.post('/order/create?columnId=' + this.column.id).then(order => {\n          if (!order) {\n           this.$message.success('免费专栏订阅成功') \n          } else {\n            // 立即支付\n            request.post('/order/pay?orderNo=' + order.orderNo).then(() => {\n              this.$message.success('支付成功，已解锁该专栏')\n              // 重新加载数据或者改变按钮状态\n            }).catch(e => {\n              this.$message.error('支付失败：' + (e.message || '余额不足'))\n            })\n          }\n        })\n      }).catch(() => {})\n    },\n    readArticle(row) {\n      if (!this.$store.getters.isLoggedIn) {\n         this.$message.warning('请登录后阅读文章')\n         return this.$router.push('/login')\n      }\n      this.$router.push('/article/' + row.id)\n    }\n  }\n}\n</script>\n\n<style scoped>\n.el-header {\n  line-height: 60px;\n  background-color: #ffffff;\n  box-shadow: 0 2px 8px rgba(0,0,0,0.08);\n}\n.logo {\n  font-size: 16px;\n  color: #606266;\n}\n.logo:hover {\n  color: #409EFF;\n}\n.top-card {\n  margin-top: 20px;\n}\n.info-layout {\n  display: flex;\n  gap: 30px;\n}\n.cover {\n  width: 300px;\n  height: 200px;\n  object-fit: cover;\n  border-radius: 8px;\n}\n.meta {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n}\n.meta h2 {\n  margin-top: 0;\n}\n.desc {\n  color: #666;\n  flex: 1;\n}\n.price {\n  font-size: 24px;\n  color: #F56C6C;\n  font-weight: bold;\n}\n.price.free {\n  color: #67C23A;\n}\n.actions {\n  display: flex;\n  align-items: center;\n  margin-top: 20px;\n}\n::v-deep .pointer-row {\n  cursor: pointer;\n}\n</style>\n"],"mappings":";AAgDA,OAAAA,OAAA;AAEA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,MAAA;MACAC,QAAA;IACA;EACA;EACAC,OAAA,WAAAA,QAAA;IACA,KAAAC,SAAA;EACA;EACAC,OAAA;IACAD,SAAA,WAAAA,UAAA;MAAA,IAAAE,KAAA;MACA,IAAAC,EAAA,QAAAC,MAAA,CAAAC,MAAA,CAAAF,EAAA;MACAR,OAAA,CAAAW,GAAA,cAAAH,EAAA,EAAAI,IAAA,WAAAC,GAAA;QACAN,KAAA,CAAAL,MAAA,GAAAW,GAAA;MACA;MACAb,OAAA,CAAAW,GAAA,oBAAAH,EAAA,EAAAI,IAAA,WAAAC,GAAA;QACAN,KAAA,CAAAJ,QAAA,GAAAU,GAAA;MACA;IACA;IACAC,SAAA,WAAAA,UAAA;MAAA,IAAAC,MAAA;MACA,UAAAC,MAAA,CAAAC,OAAA,CAAAC,UAAA;QACA,KAAAC,QAAA,CAAAC,OAAA;QACA,YAAAC,OAAA,CAAAC,IAAA;MACA;MACA,KAAAC,QAAA,yDAAAC,MAAA,MAAAtB,MAAA,CAAAuB,KAAA;QACAC,IAAA;MACA,GAAAd,IAAA;QACA;QACAZ,OAAA,CAAA2B,IAAA,6BAAAZ,MAAA,CAAAb,MAAA,CAAAM,EAAA,EAAAI,IAAA,WAAAgB,KAAA;UACA,KAAAA,KAAA;YACAb,MAAA,CAAAI,QAAA,CAAAU,OAAA;UACA;YACA;YACA7B,OAAA,CAAA2B,IAAA,yBAAAC,KAAA,CAAAE,OAAA,EAAAlB,IAAA;cACAG,MAAA,CAAAI,QAAA,CAAAU,OAAA;cACA;YACA,sBAAAE,CAAA;cACAhB,MAAA,CAAAI,QAAA,CAAAa,KAAA,YAAAD,CAAA,CAAAE,OAAA;YACA;UACA;QACA;MACA;IACA;IACAC,WAAA,WAAAA,YAAAC,GAAA;MACA,UAAAnB,MAAA,CAAAC,OAAA,CAAAC,UAAA;QACA,KAAAC,QAAA,CAAAC,OAAA;QACA,YAAAC,OAAA,CAAAC,IAAA;MACA;MACA,KAAAD,OAAA,CAAAC,IAAA,eAAAa,GAAA,CAAA3B,EAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}