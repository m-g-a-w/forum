ice > 0\">¥ {{ column.price }}</span>\n                <span class=\"price free\" v-else>免费</span>\n                <el-button v-if=\"!isSubscribed\" type=\"success\" @click=\"subscribe\" style=\"margin-left: 20px;\">\n                  {{ column.price > 0 ? '订阅专栏' : '免费加入' }}\n                </el-button>\n                <el-tag v-else type=\"success\" style=\"margin-left: 20px;\">✓ 已订阅</el-tag>\n              </div>\n            </div>\n          </div>\n        </el-card>\n\n        <!-- 文章列表 -->\n        <el-card class=\"article-card\" style=\"margin-top: 20px;\">\n          <div slot=\"header\" class=\"clearfix\">\n            <span>专栏目录</span>\n          </div>\n          <el-table :data=\"articles\" style=\"width: 100%\" @row-click=\"readArticle\" row-class-name=\"pointer-row\">\n            <el-table-column prop=\"title\" label=\"文章标题\"></el-table-column>\n            <el-table-column label=\"阅读权限\" width=\"120\">\n              <template slot-scope=\"scope\">\n                <el-tag :type=\"scope.row.isFree ? 'success' : 'warning'\" size=\"small\">\n                  {{ scope.row.isFree ? '免费试读' : '付费内容' }}\n                </el-tag>\n              </template>\n            </el-table-column>\n            <el-table-column prop=\"createTime\" label=\"发布时间\" width=\"200\"></el-table-column>\n          </el-table>\n        </el-card>\n      </el-main>\n    </el-container>\n  </div>\n</template>\n\n<script>\nimport request from '@/api/request'\n\nexport default {\n  data() {\n    return {\n      column: null,\n      articles: [],\n      isSubscribed: false\n    }\n  },\n  created() {\n    this.fetchData()\n  },\n  methods: {\n    fetchData() {\n      const id = this.$route.params.id\n      request.get('/column/' + id).then(res => {\n        this.column = res\n        // 检查是否已订阅\n        this.checkSubscription()\n      })\n      request.get('/article/list/' + id).then(res => {\n        this.articles = res\n      })\n    },\n    checkSubscription() {\n      if (!this.$store.getters.isLoggedIn || !this.column) return\n      request.get('/subscription/check?columnId=' + this.column.id).then(res => {\n        this.isSubscribed = res === true || res === 'true'\n      }).catch(() => {})\n    },\n    subscribe() {\n      if (!this.$store.getters.isLoggedIn) {\n        this.$message.warning('请先登录系统')\n        return this.$router.push('/login')\n      }\n      if (this.isSubscribed) {\n        this.$message.info('您已订阅该专栏')\n        return\n      }\n      // 免费专栏：直接订阅，无需确认\n      if (this.column.price === 0) {\n        request.post('/order/create?columnId=' + this.column.id).then(() => {\n          this.$message.success('免费专栏订阅成功！')\n          this.isSubscribed = true\n        }).catch(() => {})\n        return\n      }\n      // 付费专栏：弹出确认框\n      this.$confirm(`确认要订阅 《${this.column.title}》 吗？将从余额中扣除 ¥${this.column.price}`, '确认订阅', {\n        type: 'warning',\n        confirmButtonText: '确认支付',\n        cancelButtonText: '取消'\n      }).then(() => {\n        request.post('/order/create?columnId=' + this.column.id).then(order => {\n          if (!order) {\n            this.$message.success('订阅成功')\n            this.isSubscribed = true\n          } else {\n            request.post('/order/pay?orderNo=' + order.orderNo).then(() => {\n              this.$message.success('支付成功，已解锁该专栏 🎉')\n              this.isSubscribed = true\n            }).catch(() => {})\n          }\n        })\n      }).catch(() => {})\n    },\n    readArticle(row) {\n      if (!this.$store.getters.isLoggedIn) {\n         this.$message.warning('请登录后阅读文章')\n         return this.$router.push('/login')\n      }\n      this.$router.push('/article/' + row.id)\n    }\n  }\n}\n</script>\n\n<style scoped>\n.el-header {\n  line-height: 60px;\n  background-color: #ffffff;\n  box-shadow: 0 2px 8px rgba(0,0,0,0.08);\n}\n.logo {\n  font-size: 16px;\n  color: #606266;\n}\n.logo:hover {\n  color: #409EFF;\n}\n.top-card {\n  margin-top: 20px;\n}\n.info-layout {\n  display: flex;\n  gap: 30px;\n}\n.cover {\n  width: 300px;\n  height: 200px;\n  object-fit: cover;\n  border-radius: 8px;\n}\n.meta {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n}\n.meta h2 {\n  margin-top: 0;\n}\n.desc {\n  color: #666;\n  flex: 1;\n}\n.price {\n  font-size: 24px;\n  color: #F56C6C;\n  font-weight: bold;\n}\n.price.free {\n  color: #67C23A;\n}\n.actions {\n  display: flex;\n  align-items: center;\n  margin-top: 20px;\n}\n::v-deep .pointer-row {\n  cursor: pointer;\n}\n</style>\n"],"mappings":";;AAgDA,OAAAA,OAAA;AAEA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,MAAA;MACAC,QAAA;MACAC,YAAA;IACA;EACA;EACAC,OAAA,WAAAA,QAAA;IACA,KAAAC,SAAA;EACA;EACAC,OAAA;IACAD,SAAA,WAAAA,UAAA;MAAA,IAAAE,KAAA;MACA,IAAAC,EAAA,QAAAC,MAAA,CAAAC,MAAA,CAAAF,EAAA;MACAT,OAAA,CAAAY,GAAA,cAAAH,EAAA,EAAAI,IAAA,WAAAC,GAAA;QACAN,KAAA,CAAAN,MAAA,GAAAY,GAAA;QACA;QACAN,KAAA,CAAAO,iBAAA;MACA;MACAf,OAAA,CAAAY,GAAA,oBAAAH,EAAA,EAAAI,IAAA,WAAAC,GAAA;QACAN,KAAA,CAAAL,QAAA,GAAAW,GAAA;MACA;IACA;IACAC,iBAAA,WAAAA,kBAAA;MAAA,IAAAC,MAAA;MACA,UAAAC,MAAA,CAAAC,OAAA,CAAAC,UAAA,UAAAjB,MAAA;MACAF,OAAA,CAAAY,GAAA,wCAAAV,MAAA,CAAAO,EAAA,EAAAI,IAAA,WAAAC,GAAA;QACAE,MAAA,CAAAZ,YAAA,GAAAU,GAAA,aAAAA,GAAA;MACA;IACA;IACAM,SAAA,WAAAA,UAAA;MAAA,IAAAC,MAAA;MACA,UAAAJ,MAAA,CAAAC,OAAA,CAAAC,UAAA;QACA,KAAAG,QAAA,CAAAC,OAAA;QACA,YAAAC,OAAA,CAAAC,IAAA;MACA;MACA,SAAArB,YAAA;QACA,KAAAkB,QAAA,CAAAI,IAAA;QACA;MACA;MACA;MACA,SAAAxB,MAAA,CAAAyB,KAAA;QACA3B,OAAA,CAAA4B,IAAA,kCAAA1B,MAAA,CAAAO,EAAA,EAAAI,IAAA;UACAQ,MAAA,CAAAC,QAAA,CAAAO,OAAA;UACAR,MAAA,CAAAjB,YAAA;QACA;QACA;MACA;MACA;MACA,KAAA0B,QAAA,yCAAAC,MAAA,MAAA7B,MAAA,CAAA8B,KAAA,wEAAAD,MAAA,MAAA7B,MAAA,CAAAyB,KAAA;QACAM,IAAA;QACAC,iBAAA;QACAC,gBAAA;MACA,GAAAtB,IAAA;QACAb,OAAA,CAAA4B,IAAA,6BAAAP,MAAA,CAAAnB,MAAA,CAAAO,EAAA,EAAAI,IAAA,WAAAuB,KAAA;UACA,KAAAA,KAAA;YACAf,MAAA,CAAAC,QAAA,CAAAO,OAAA;YACAR,MAAA,CAAAjB,YAAA;UACA;YACAJ,OAAA,CAAA4B,IAAA,yBAAAQ,KAAA,CAAAC,OAAA,EAAAxB,IAAA;cACAQ,MAAA,CAAAC,QAAA,CAAAO,OAAA;cACAR,MAAA,CAAAjB,YAAA;YACA;UACA;QACA;MACA;IACA;IACAkC,WAAA,WAAAA,YAAAC