{"ast":null,"code":"import \"core-js/modules/es.array.concat.js\";\nimport \"core-js/modules/es.array.push.js\";\nimport request from '@/api/request';\nexport default {\n  data: function data() {\n    return {\n      column: null,\n      articles: [],\n      isSubscribed: false\n    };\n  },\n  created: function created() {\n    this.fetchData();\n  },\n  methods: {\n    fetchData: function fetchData() {\n      var _this = this;\n      var id = this.$route.params.id;\n      request.get('/column/' + id).then(function (res) {\n        _this.column = res;\n        // 检查是否已订阅\n        _this.checkSubscription();\n      });\n      request.get('/article/list/' + id).then(function (res) {\n        _this.articles = res;\n      });\n    },\n    checkSubscription: function checkSubscription() {\n      var _this2 = this;\n      if (!this.$store.getters.isLoggedIn || !this.column) return;\n      request.get('/subscription/check?columnId=' + this.column.id).then(function (res) {\n        _this2.isSubscribed = res === true || res === 'true';\n      })[\"catch\"](function () {});\n    },\n    subscribe: function subscribe() {\n      var _this3 = this;\n      if (!this.$store.getters.isLoggedIn) {\n        this.$message.warning('请先登录系统');\n        return this.$router.push('/login');\n      }\n      if (this.isSubscribed) {\n        this.$message.info('您已订阅该专栏');\n        return;\n      }\n      // 免费专栏：直接订阅，无需确认\n      if (this.column.price === 0) {\n        request.post('/order/create?columnId=' + this.column.id).then(function () {\n          _this3.$message.success('免费专栏订阅成功！');\n          _this3.isSubscribed = true;\n        })[\"catch\"](function () {});\n        return;\n      }\n      // 付费专栏：弹出确认框\n      this.$confirm(\"\\u786E\\u8BA4\\u8981\\u8BA2\\u9605 \\u300A\".concat(this.column.title, \"\\u300B \\u5417\\uFF1F\\u5C06\\u4ECE\\u4F59\\u989D\\u4E2D\\u6263\\u9664 \\xA5\").concat(this.column.price), '确认订阅', {\n        type: 'warning',\n        confirmButtonText: '确认支付',\n     