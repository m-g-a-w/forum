{"ast":null,"code":"import \"core-js/modules/es.array.includes.js\";\nimport \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.string.includes.js\";\nimport request from '@/api/request';\nexport default {\n  data: function data() {\n    return {\n      article: null,\n      showPaywall: false\n    };\n  },\n  computed: {\n    contentHtml: function contentHtml() {\n      // 真实项目中可以用 marked.js 等库将 Markdown 转为 HTML\n      // 这里简易处理，直接原样输出或用 <pre> 包裹，考虑到我们假设保存的是富文本HTML或者存粹文本\n      // 如果触发了 paywall，仅展示一部分\n      if (!this.article) return '';\n      return this.article.content;\n    }\n  },\n  created: function created() {\n    this.fetchData();\n  },\n  methods: {\n    fetchData: function fetchData() {\n      var _this = this;\n      var id = this.$route.params.id;\n      request.get('/article/' + id).then(function (res) {\n        _this.article = res;\n        // 前端简易防泄漏，实际鉴权应严格放在后端\n        request.get('/column/' + _this.article.columnId).then(function (col) {\n          if (col.price > 0 && !_this.article.isFree) {\n            // 进一步校验是否订阅，或者直接依赖后端在没买时返回特定标识\n            // 这里简化为：先拦截显示paywall，除非后端有一个明确的已购标识 (后端返回的 article 其实没有这个字段目前)\n            // 暂时通过调用接口尝试看是否能拉取到正常数据，或者通过一个通用的订阅检查接口\n            request.get(\"/order/check?columnId=\".concat(_this.article.columnId))[\"catch\"](function () {\n              // 接口未实现或失败则假定未购\n              // 等会如果需要严格，应当调用 subscription 检查接口\n            });\n          }\n        });\n      })[\"catch\"](function (err) {\n        if (err.message === '未解锁' || err.message.includes('购买')) {\n          _this.showPaywall = true;\n          // 防止抛错崩溃，如果后端直接拦截\n        }\n      });\n    },\n    goBack: function goBack() {\n      if (this.article) {\n        this.$router.push('/column/' + this.article.columnId);\n      } else {\n        this.$router.back();\n      }\n    },\n    goToColumn: function goToColumn() {\n      if (this.article) {\n        this.$router.push('/column/' + this.article.columnId);\n      }\n    }\n  }\n};","map":{"version":3,"names":["request","data","article","showPaywall","computed","contentHtml","content","created","fetchData","methods","_this","id","$route","params","get","then","res","columnId","col","price","isFree","concat","err","message","includes","goBack","$router","push","back","goToColumn"],"sources":["src/views/ArticleView.vue"],"sourcesContent":["<template>\n  <div class=\"article-view\">\n    <el-container v-if=\"article\">\n      <el-header height=\"60px\">\n        <div class=\"nav-back\" @click=\"goBack\" style=\"cursor: pointer;\">&lt; 返回专栏</div>\n      </el-header>\n      <el-main class=\"article-main\">\n        <h1 class=\"title\">{{ article.title }}</h1>\n        <div class=\"meta\">\n          <span>发表于: {{ article.createTime }}</span>\n        </div>\n        <el-divider></el-divider>\n        \n        <div class=\"content markdown-body\" v-html=\"contentHtml\"></div>\n        \n        <div class=\"paywall-overlay\" v-if=\"showPaywall\">\n          <div class=\"paywall-box\">\n            <h3>本文为付费专栏内容</h3>\n            <p>需解锁对应专栏以阅读全文</p>\n            <el-button type=\"success\" @click=\"goToColumn\">去解锁专栏 / 了解详情</el-button>\n          </div>\n        </div>\n        \n        <el-divider v-if=\"!showPaywall\"></el-divider>\n        <!-- 评论区 TODO -->\n      </el-main>\n    </el-container>\n  </div>\n</template>\n\n<script>\nimport request from '@/api/request'\n\nexport default {\n  data() {\n    return {\n      article: null,\n      showPaywall: false\n    }\n  },\n  computed: {\n    contentHtml() {\n      // 真实项目中可以用 marked.js 等库将 Markdown 转为 HTML\n      // 这里简易处理，直接原样输出或用 <pre> 包裹，考虑到我们假设保存的是富文本HTML或者存粹文本\n      // 如果触发了 paywall，仅展示一部分\n      if (!this.article) return ''\n      return this.article.content\n    }\n  },\n  created() {\n    this.fetchData()\n  },\n  methods: {\n    fetchData() {\n      const id = this.$route.params.id\n      request.get('/article/' + id).then(res => {\n        this.article = res\n        // 前端简易防泄漏，实际鉴权应严格放在后端\n        request.get('/column/' + this.article.columnId).then(col => {\n           if (col.price > 0 && !this.article.isFree) {\n              // 进一步校验是否订阅，或者直接依赖后端在没买时返回特定标识\n              // 这里简化为：先拦截显示paywall，除非后端有一个明确的已购标识 (后端返回的 article 其实没有这个字段目前)\n              // 暂时通过调用接口尝试看是否能拉取到正常数据，或者通过一个通用的订阅检查接口\n              request.get(`/order/check?columnId=${this.article.columnId}`).catch(() => {\n                 // 接口未实现或失败则假定未购\n                 // 等会如果需要严格，应当调用 subscription 检查接口\n              })\n           }\n        })\n      }).catch(err => {\n        if(err.message === '未解锁' || err.message.includes('购买')) {\n           this.showPaywall = true\n           // 防止抛错崩溃，如果后端直接拦截\n        }\n      })\n    },\n    goBack() {\n      if (this.article) {\n        this.$router.push('/column/' + this.article.columnId)\n      } else {\n        this.$router.back()\n      }\n    },\n    goToColumn() {\n      if (this.article) {\n        this.$router.push('/column/' + this.article.columnId)\n      }\n    }\n  }\n}\n</script>\n\n<style scoped>\n.el-header {\n  line-height: 60px;\n  background-color: #ffffff;\n  border-bottom: 1px solid #ebeef5;\n}\n.nav-back {\n  font-size: 15px;\n  color: #606266;\n}\n.nav-back:hover {\n  color: #409EFF;\n}\n.article-main {\n  max-width: 800px;\n  margin: 20px auto;\n  position: relative;\n  background: #fff;\n  padding: 40px;\n  border-radius: 8px;\n  min-height: 500px;\n}\n.title {\n  text-align: center;\n  font-size: 28px;\n  color: #303133;\n}\n.meta {\n  text-align: center;\n  color: #909399;\n  font-size: 13px;\n  margin-bottom: 20px;\n}\n.content {\n  line-height: 1.8;\n  font-size: 16px;\n  color: #333;\n  margin-bottom: 60px;\n}\n.paywall-overlay {\n  position: absolute;\n  bottom: 0;\n  left: 0;\n  width: 100%;\n  height: 60%;\n  background: linear-gradient(to bottom, rgba(255,255,255,0) 0%, rgba(255,255,255,1) 40%);\n  display: flex;\n  justify-content: center;\n  align-items: flex-end;\n  padding-bottom: 50px;\n  border-radius: 0 0 8px 8px;\n}\n.paywall-box {\n  text-align: center;\n  background: #fdfdfd;\n  padding: 30px;\n  border: 1px solid #ebeef5;\n  border-radius: 8px;\n  box-shadow: 0 2px 12px 0 rgba(0,0,0,0.1);\n}\n.paywall-box h3 {\n  margin-top: 0;\n  color: #F56C6C;\n}\n</style>\n"],"mappings":";;;AA+BA,OAAAA,OAAA;AAEA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,OAAA;MACAC,WAAA;IACA;EACA;EACAC,QAAA;IACAC,WAAA,WAAAA,YAAA;MACA;MACA;MACA;MACA,UAAAH,OAAA;MACA,YAAAA,OAAA,CAAAI,OAAA;IACA;EACA;EACAC,OAAA,WAAAA,QAAA;IACA,KAAAC,SAAA;EACA;EACAC,OAAA;IACAD,SAAA,WAAAA,UAAA;MAAA,IAAAE,KAAA;MACA,IAAAC,EAAA,QAAAC,MAAA,CAAAC,MAAA,CAAAF,EAAA;MACAX,OAAA,CAAAc,GAAA,eAAAH,EAAA,EAAAI,IAAA,WAAAC,GAAA;QACAN,KAAA,CAAAR,OAAA,GAAAc,GAAA;QACA;QACAhB,OAAA,CAAAc,GAAA,cAAAJ,KAAA,CAAAR,OAAA,CAAAe,QAAA,EAAAF,IAAA,WAAAG,GAAA;UACA,IAAAA,GAAA,CAAAC,KAAA,SAAAT,KAAA,CAAAR,OAAA,CAAAkB,MAAA;YACA;YACA;YACA;YACApB,OAAA,CAAAc,GAAA,0BAAAO,MAAA,CAAAX,KAAA,CAAAR,OAAA,CAAAe,QAAA;cACA;cACA;YAAA,CACA;UACA;QACA;MACA,sBAAAK,GAAA;QACA,IAAAA,GAAA,CAAAC,OAAA,cAAAD,GAAA,CAAAC,OAAA,CAAAC,QAAA;UACAd,KAAA,CAAAP,WAAA;UACA;QACA;MACA;IACA;IACAsB,MAAA,WAAAA,OAAA;MACA,SAAAvB,OAAA;QACA,KAAAwB,OAAA,CAAAC,IAAA,mBAAAzB,OAAA,CAAAe,QAAA;MACA;QACA,KAAAS,OAAA,CAAAE,IAAA;MACA;IACA;IACAC,UAAA,WAAAA,WAAA;MACA,SAAA3B,OAAA;QACA,KAAAwB,OAAA,CAAAC,IAAA,mBAAAzB,OAAA,CAAAe,QAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}