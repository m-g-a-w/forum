4 = this;\n      var newStatus = row.status === 1 ? 0 : 1;\n      request.post(\"/admin/user/status?id=\".concat(row.id, \"&status=\").concat(newStatus)).then(function () {\n        _this4.$message.success('更新状态成功');\n        row.status = newStatus;\n      });\n    },\n    changeColumnStatus: function changeColumnStatus(row) {\n      var _this5 = this;\n      var newStatus = row.status === 1 ? 0 : 1;\n      request.post(\"/admin/column/status?id=\".concat(row.id, \"&status=\").concat(newStatus)).then(function () {\n        _this5.$message.success('更新状态成功');\n        row.status = newStatus;\n      });\n    }\n  })\n};","map":{"version":3,"names":["request","mapState","mapMutations","data","activeTab","stat","userCount","columnCount","orderCount","users","columns","computed","_objectSpread","created","fetchDashboard","methods","handleCommand","cmd","LOGOUT","$message","success","$router","push","handleSelect","index","fetchUsers","fetchColumns","_this","get","then","res","_this2","_this3","changeUserStatus","row","_this4","newStatus","status","post","concat","id","changeColumnStatus","_this5"],"sources":["src/views/AdminView.vue"],"sourcesContent":["<template>\n  <div class=\"admin-container\">\n    <el-container style=\"height: 100vh;\">\n      <el-aside width=\"220px\" class=\"fade-in\">\n        <div class=\"logo\" @click=\"$router.push('/')\">\n          <i class=\"el-icon-back\"></i> 返回首页\n        </div>\n        <el-menu\n          default-active=\"dashboard\"\n          class=\"el-menu-vertical\"\n          @select=\"handleSelect\"\n        >\n          <el-menu-item index=\"dashboard\">\n            <i class=\"el-icon-data-line\"></i>\n            <span slot=\"title\">数据看板</span>\n          </el-menu-item>\n          <el-menu-item index=\"users\">\n            <i class=\"el-icon-user\"></i>\n            <span slot=\"title\">用户管理</span>\n          </el-menu-item>\n          <el-menu-item index=\"columns\">\n            <i class=\"el-icon-document\"></i>\n            <span slot=\"title\">专栏审核</span>\n          </el-menu-item>\n        </el-menu>\n      </el-aside>\n\n      <el-container>\n        <el-header height=\"60px\" class=\"admin-header fade-in\">\n          <div class=\"header-right\">\n            <el-dropdown v-if=\"user\" @command=\"handleCommand\">\n              <span class=\"user-dropdown\">\n                <el-avatar size=\"small\" :src=\"user?.avatar || (user ? 'https://api.dicebear.com/7.x/avataaars/png?seed=' + user.username : 'https://api.dicebear.com/7.x/avataaars/png?seed=default')\"></el-avatar>\n                <span class=\"username\">{{ user?.username }}</span>\n                <i class=\"el-icon-arrow-down el-icon--right\"></i>\n              </span>\n              <el-dropdown-menu slot=\"dropdown\">\n                <el-dropdown-item command=\"home\"><i class=\"el-icon-s-home\"></i> 返回前台</el-dropdown-item>\n                <el-dropdown-item command=\"logout\" divided><i class=\"el-icon-switch-button\"></i> 退出登录</el-dropdown-item>\n              </el-dropdown-menu>\n            </el-dropdown>\n          </div>\n        </el-header>\n\n        <el-main class=\"fade-in\" style=\"animation-delay: 0.2s\">\n          <!-- 数据看板 -->\n          <div v-show=\"activeTab === 'dashboard'\">\n             <h2>全局数据看板</h2>\n             <el-row :gutter=\"20\" style=\"margin-top: 20px;\">\n               <el-col :span=\"8\">\n                 <el-card shadow=\"always\">\n                    <div class=\"card-title\">总注册用户</div>\n                    <div class=\"card-num\">{{ stat.userCount }}</div>\n                 </el-card>\n               </el-col>\n               <el-col :span=\"8\">\n                 <el-card shadow=\"always\">\n                    <div class=\"card-title\">专栏总数</div>\n                    <div class=\"card-num\">{{ stat.columnCount }}</div>\n                 </el-card>\n               </el-col>\n               <el-col :span=\"8\">\n                 <el-card shadow=\"always\">\n                    <div class=\"card-title\">支付订单总数</div>\n                    <div class=\"card-num\">{{ stat.orderCount }}</div>\n                 </el-card>\n               </el-col>\n             </el-row>\n          </div>\n\n          <!-- 用户管理 -->\n          <div v-show=\"activeTab === 'users'\">\n             <h2>用户管理</h2>\n             <el-table :data=\"users\" border style=\"width: 100%\">\n               <el-table-column prop=\"id\" label=\"ID\" width=\"80\"></el-table-column>\n               <el-table-column prop=\"username\" label=\"用户名\"></el-table-column>\n               <el-table-column prop=\"email\" label=\"邮箱\"></el-table-column>\n              <el-table-column label=\"角色\">\n                <template slot-scope=\"scope\">\n                  <el-tag v-if=\"scope.row.role === 2\" type=\"danger\">管理员</el-tag>\n                  <el-tag v-else-if=\"scope.row.columnCount > 0\" type=\"success\">创作者</el-tag>\n                  <el-tag v-else type=\"info\">普通用户</el-tag>\n                </template>\n              </el-table-column>\n               <el-table-column label=\"状态\" width=\"100\">\n                 <template slot-scope=\"scope\">\n                   <el-tag :type=\"scope.row.status === 1 ? 'success' : 'danger'\">\n                     {{ scope.row.status === 1 ? '正常' : '封禁' }}\n                   </el-tag>\n                 </template>\n               </el-table-column>\n               <el-table-column label=\"操作\" width=\"150\" v-if=\"user?.role === 2\">\n                 <template slot-scope=\"scope\">\n                   <el-button \n                     size=\"mini\" \n                     :type=\"scope.row.status === 1 ? 'danger' : 'success'\"\n                     @click=\"changeUserStatus(scope.row)\"\n                     v-if=\"scope.row.role !== 2\"\n                   >\n                     {{ scope.row.status === 1 ? '封禁' : '解封' }}\n                   </el-button>\n                 </template>\n               </el-table-column>\n             </el-table>\n          </div>\n\n          <!-- 专栏审核 -->\n          <div v-show=\"activeTab === 'columns'\">\n             <h2>专栏内容管理</h2>\n             <el-table :data=\"columns\" border style=\"width: 100%\">\n               <el-table-column prop=\"id\" label=\"ID\" width=\"80\"></el-table-column>\n               <el-table-column prop=\"title\" label=\"专栏标题\"></el-table-column>\n               <el-table-column prop=\"creatorId\" label=\"创作者ID\" width=\"100\"></el-table-column>\n               <el-table-column label=\"状态\" width=\"100\">\n                 <template slot-scope=\"scope\">\n                   <el-tag :type=\"scope.row.status === 1 ? 'success' : 'danger'\">\n                     {{ scope.row.status === 1 ? '上架中' : '已下架' }}\n                   </el-tag>\n                 </template>\n               </el-table-column>\n               <el-table-column label=\"操作\" width=\"150\">\n                 <template slot-scope=\"scope\">\n                   <el-button \n                     size=\"mini\" \n                     :type=\"scope.row.status === 1 ? 'danger' : 'success'\"\n                     @click=\"changeColumnStatus(scope.row)\"\n                   >\n                     {{ scope.row.status === 1 ? '强制下架' : '恢复上架' }}\n                   </el-button>\n                 </template>\n               </el-table-column>\n             </el-table>\n          </div>\n        </el-main>\n      </el-container>\n    </el-container>\n  </div>\n</template>\n\n<script>\nimport request from '@/api/request'\nimport { mapState, mapMutations } from 'vuex'\n\nexport default {\n  data() {\n    return {\n      activeTab: 'dashboard',\n      stat: {\n        userCount: 0,\n        columnCount: 0,\n        orderCount: 0\n      },\n      users: [],\n      columns: []\n    }\n  },\n  computed: {\n    ...mapState(['user'])\n  },\n  created() {\n    this.fetchDashboard()\n  },\n  methods: {\n    ...mapMutations(['LOGOUT']),\n    handleCommand(cmd) {\n      if (cmd === 'logout') {\n        this.LOGOUT()\n        this.$message.success('已安全退出')\n        this.$router.push('/login')\n      } else if (cmd === 'home') {\n        this.$router.push('/')\n      }\n    },\n    handleSelect(index) {\n      if (index === 'back') {\n        this.$router.push('/')\n        return\n      }\n      this.activeTab = index\n      if (index === 'dashboard') this.fetchDashboard()\n      if (index === 'users') this.fetchUsers()\n      if (index === 'columns') this.fetchColumns()\n    },\n    fetchDashboard() {\n      request.get('/admin/dashboard').then(res => {\n        this.stat = res\n      })\n    },\n    fetchUsers() {\n      request.get('/admin/users').then(res => {\n        this.users = res\n      })\n    },\n    fetchColumns() {\n      request.get('/admin/columns').then(res => {\n        this.columns = res\n      })\n    },\n    changeUserStatus(row) {\n      const newStatus = row.status === 1 ? 0 : 1\n      request.post(`/admin/user/status?id=${row.id}&status=${newStatus}`).then(() => {\n        this.$message.success('更新状态成功')\n        row.status = newStatus\n      })\n    },\n    changeColumnStatus(row) {\n      const newStatus = row.status === 1 ? 0 : 1\n      request.post(`/admin/column/status?id=${row.id}&status=${newStatus}`).then(() => {\n        this.$message.success('更新状态成功')\n        row.status = newStatus\n      })\n    }\n  }\n}\n</script>\n\n<style scoped>\n.admin-container {\n  --theme-color: #1a365d;\n  --theme-light: #4299e1;\n  --theme-bg: #f7fafc;\n}\n.admin-header {\n  background-color: #fff;\n  color: #333;\n  line-height: 60px;\n  border-bottom: 1px solid #e2e8f0;\n  display: flex;\n  align-items: center;\n  justify-content: flex-end;\n  padding: 0 20px;\n}\n.header-right {\n  display: flex;\n  align-items: center;\n}\n.user-dropdown {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  color: #333;\n  cursor: pointer;\n  font-weight: 500;\n  padding: 6px 12px;\n  border-radius: 20px;\n  transition: background-color 0.3s;\n}\n.user-dropdown:hover {\n  background-color: #f5f7fa;\n}\n.username {\n  font-size: 14px;\n}\n::v-deep .el-avatar > img {\n  object-fit: cover !important;\n  width: 100%;\n  height: 100%;\n}\n.logo {\n  height: 60px;\n  line-height: 60px;\n  text-align: center;\n  color: #fff;\n  font-size: 18px;\n  font-weight: bold;\n  background: linear-gradient(135deg, #2c5282 0%, #4299e1 100%);\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 5px;\n  transition: all 0.3s;\n}\n.logo:hover {\n  background: linear-gradient(135deg, #2c5282 0%, #63b3ed 100%);\n}\n.logo i {\n  font-weight: normal;\n}\n.card-title {\n  color: #4299e1;\n  font-size: 14px;\n}\n.card-num {\n  font-size: 32px;\n  color: #2c5282;\n  margin-top: 10px;\n  font-weight: bold;\n}\n\n/* 科技蓝侧边栏 */\n.el-aside {\n  background: linear-gradient(180deg, #2c5282 0%, #4299e1 50%, #2c5282 100%) !important;\n}\n.el-menu {\n  border-right: none !important;\n  background: transparent !important;\n}\n.el-menu-item {\n  margin: 4px 8px;\n  border-radius: 8px;\n  color: #e2e8f0 !important;\n}\n.el-menu-item i {\n  color: #e2e8f0 !important;\n}\n.el-menu-item:hover {\n  background-color: rgba(66, 153, 225, 0.3) !important;\n}\n.el-menu-item.is-active {\n  background-color: #4299e1 !important;\n  color: #fff !important;\n}\n.el-menu-item.is-active i {\n  color: #fff !important;\n}\n</style>\n"],"mappings":";;;AA4IA,OAAAA,OAAA;AACA,SAAAC,QAAA,EAAAC,YAAA;AAEA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,SAAA;MACAC,IAAA;QACAC,SAAA;QACAC,WAAA;QACAC,UAAA;MACA;MACAC,KAAA;MACAC,OAAA;IACA;EACA;EACAC,QAAA,EAAAC,aAAA,KACAX,QAAA,WACA;EACAY,OAAA,WAAAA,QAAA;IACA,KAAAC,cAAA;EACA;EACAC,OAAA,EAAAH,aAAA,CAAAA,aAAA,KACAV,YAAA;IACAc,aAAA,WAAAA,cAAAC,GAAA;MACA,IAAAA,GAAA;QACA,KAAAC,MAAA;QACA,KAAAC,QAAA,CAAAC,OAAA;QACA,KAAAC,OAAA,CAAAC,IAAA;MACA,WAAAL,GAAA;QACA,KAAAI,OAAA,CAAAC,IAAA;MACA;IACA;IACAC,YAAA,WAAAA,aAAAC,KAAA;MACA,IAAAA,KAAA;QACA,KAAAH,OAAA,CAAAC,IAAA;QACA;MACA;MACA,KAAAlB,SAAA,GAAAoB,KAAA;MACA,IAAAA,