"src/views/LoginView.vue"],"sourcesContent":["<template>\n  <div class=\"login-container\">\n    <el-card class=\"login-card\">\n      <h2 style=\"text-align: center;\">{{ loginForm.role === 'admin' ? '管理员登录' : '论坛 - 登录' }}</h2>\n      <el-form :model=\"loginForm\" :rules=\"rules\" ref=\"loginForm\" label-width=\"80px\">\n        <el-form-item label=\"用户名\" prop=\"username\">\n          <el-input v-model=\"loginForm.username\" placeholder=\"请输入用户名\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"密码\" prop=\"password\">\n          <el-input type=\"password\" v-model=\"loginForm.password\" placeholder=\"请输入密码\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"登录类型\" prop=\"role\">\n          <el-radio-group v-model=\"loginForm.role\">\n            <el-radio label=\"user\">用户</el-radio>\n            <el-radio label=\"admin\">管理员</el-radio>\n          </el-radio-group>\n        </el-form-item>\n        <el-form-item>\n          <el-button type=\"primary\" @click=\"handleLogin\" style=\"width: 100%;\">\n            {{ loginForm.role === 'admin' ? '管理员登录' : '登录' }}\n          </el-button>\n        </el-form-item>\n        <div style=\"text-align: right; font-size: 14px;\" v-if=\"loginForm.role === 'user'\">\n          还没有账号？ <el-link type=\"primary\" @click=\"$router.push('/register')\">去注册</el-link>\n        </div>\n      </el-form>\n    </el-card>\n  </div>\n</template>\n\n<script>\nimport request from '@/api/request'\nimport { mapMutations } from 'vuex'\n\nexport default {\n  data() {\n    return {\n      loginForm: {\n        username: '',\n        password: '',\n        role: 'user'\n      },\n      rules: {\n        username: [{ required: true, message: '请输入用户名', trigger: 'blur' }],\n        password: [{ required: true, message: '请输入密码', trigger: 'blur' }],\n        role: [{ required: true, message: '请选择登录类型', trigger: 'change' }]\n      }\n    }\n  },\n  methods: {\n    ...mapMutations(['SET_TOKEN', 'SET_USER']),\n    handleLogin() {\n      this.$refs.loginForm.validate(valid => {\n        if (valid) {\n          request.post('/user/login', this.loginForm).then(res => {\n            this.SET_TOKEN(res.token)\n            this.SET_USER(res.user)\n            this.$message.success('登录成功')\n            if (this.loginForm.role === 'admin') {\n              this.$router.push('/admin')\n            } else {\n              this.$router.push('/')\n            }\n          }).catch((err) => {\n            if (err && err.message) {\n              this.$message.error(err.message)\n            }\n          })\n        }\n      })\n    }\n  }\n}\n</script>\n\n<style scoped>\n.login-container {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  height: 100vh;\n  background-color: #f0f2f5;\n}\n.login-card {\n  width: 400px;\n  padding: 20px;\n}\n</style>\n"],"mappings":";;AA+BA,OAAAA,OAAA;AACA,SAAAC,YAAA;AAEA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,SAAA;QACAC,QAAA;QACAC,QAAA;QACAC,IAAA;MACA;MACAC,KAAA;QACAH,QAAA;UAAAI,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAL,QAAA;UAAAG,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAJ,IAAA;UAAAE,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAC,OAAA,EAAAC,aAAA,CAAAA,aAAA,KACAX,YAAA;IACAY,WAAA,WAAAA,YAAA;MAAA,IAAAC,KAAA;MACA,KAAAC,KAAA,CAAAZ,SAAA,CAAAa,QAAA,WAAAC,KAAA;QACA,IAAAA,KAAA;UACAjB,OAAA,CAAAkB,IAAA,gBAAAJ,KAAA,CAAAX,SAAA,EAAAgB,IAAA,WAAAC,GAAA;YACAN,KAAA,CAAAO,SAAA,CAAAD,GAAA,CAAAE,KAAA;YACAR,KAAA,CAAAS,QAAA,CAAAH,GAAA,CAAAI,IAAA;YACAV,KAAA,CAAAW,QAAA,CAAAC,OAAA;YACA,IAAAZ,KAAA,CAAAX,SAAA,CAAAG,IAAA;cACAQ,KAAA,CAAAa,OAAA,CAAAC,IAAA;YACA;cACAd,KAAA,CAAAa,OAAA,CAAAC,IAAA;YACA;UACA,sBAAAC,GAAA;YACA,IAAAA,GAAA,IAAAA,GAAA,CAAApB,OAAA;cACAK,KAAA,CAAAW,QAAA,CAAAK,KAAA,CAAAD,GAAA,CAAApB,OAAA;YACA;UACA;QACA;MACA;IACA;EAAA;AAEA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}